n(Q_electric, T_plate_est, T_amb)\n366\t        Q_net = Q_electric * (1 - f_loss)\n367\t\n368\t    T_out_ch = chimney_outlet_temp(rr[\"T_air\"][-1], T_amb, m_dot)\n369\t    dp_b = buoyancy_pressure(m_dot, T_inlet, T_amb, rr, T_out_ch)\n370\t    dp_f, dp_details = friction_pressure(m_dot, T_inlet, T_amb, rr, T_out_ch, wind_speed)\n371\t\n372\t    z_mid = np.searchsorted(rr[\"z\"], G.RISER_LENGTH_HEATED / 2)\n373\t    z_mid = min(z_mid, len(rr[\"T_F\"]) - 1)\n374\t\n375\t    return dict(m_dot=m_dot, riser=rr, T_out_chimney=T_out_ch,\n376\t                dp_buoy=dp_b, dp_fric=dp_f, dp_details=dp_details,\n377\t                Q_electric=Q_electric, Q_net=Q_net, f_loss=f_loss,\n378\t                Q_dura=Q_dura, Q_super=Q_super,\n379\t                T_plate_mid=rr[\"T_plate\"][z_mid], T_F_mid=rr[\"T_F\"][z_mid],\n380\t                T_S_mid=rr[\"T_S\"][z_mid], T_R_mid=rr[\"T_R\"][z_mid],\n381\t                idx_mid=z_mid, T_amb=T_amb, T_inlet=T_inlet, wind=wind_speed)\n382\t"}]},"parent_tool_use_id":null,"session_id":"cb82dd2c-52a6-4b61-83fc-ac229ab3a2dd","uuid":"27c25743-7e8e-4ecf-8954-b70565259656","timestamp":"2026-07-01T22:15:04.840Z","tool_use_result":{"type":"text","file":{"filePath":"/root/bench/repB_sonnet/output/model/loop_solver.py","content":"def solve_case(Q_electric, T_amb, T_inlet, wind_speed=0.0, N=40,\n               gap=G.CAVITY_DEPTH_BASELINE, axial_shape=\"uniform\",\n               parasitic_iters=2):\n    \"\"\"Full self-consistent solve: parasitic loss <-> plate temp <-> loop\n    mass flow. Returns a result dict.\"\"\"\n    Q_net = Q_electric\n    f_loss, Q_dura, Q_super = 0.0, 0.0, 0.0\n\n    for _ in range(parasitic_iters):\n        def mismatch(m_dot):\n            try:\n                rr = march_riser(m_dot, T_inlet, Q_net, N=N, axial_shape=axial_shape, gap=gap)\n                T_out_ch = chimney_outlet_temp(rr[\"T_air\"][-1], T_amb, m_dot)\n                dp_b = buoyancy_pressure(m_dot, T_inlet, T_amb, rr, T_out_ch)\n                dp_f, _ = friction_pressure(m_dot, T_inlet, T_amb, rr, T_out_ch, wind_speed)\n                return dp_b - dp_f\n            except (ValueError, FloatingPointError):\n                # too little flow to carry the imposed heat -- solver runs into\n                # extreme temperatures; this only happens well below the real\n                # operating point, where buoyancy >> friction, so report a\n                # large positive mismatch (push the bracket search to larger m_dot)\n                return 1e9\n\n        m_lo, m_hi = 0.05, 3.0\n        lo_val, hi_val = mismatch(m_lo), mismatch(m_hi)\n        while lo_val * hi_val > 0 and m_hi < 50.0:\n            m_hi *= 2\n            hi_val = mismatch(m_hi)\n        m_dot = brentq(mismatch, m_lo, m_hi, xtol=1e-6, rtol=1e-8)\n\n        rr = march_riser(m_dot, T_inlet, Q_net, N=N, axial_shape=axial_shape, gap=gap)\n        T_plate_est = rr[\"T_plate\"].mean()\n        f_loss, Q_dura, Q_super = parasitic_loss_fraction(Q_electric, T_plate_est, T_amb)\n        Q_net = Q_electric * (1 - f_loss)\n\n    T_out_ch = chimney_outlet_temp(rr[\"T_air\"][-1], T_amb, m_dot)\n    dp_b = buoyancy_pressure(m_dot, T_inlet, T_amb, rr, T_out_ch)\n    dp_f, dp_details = friction_pressure(m_dot, T_inlet, T_amb, rr, T_out_ch, wind_speed)\n\n    z_mid = np.searchsorted(rr[\"z\"], G.RISER_LENGTH_HEATED / 2)\n    z_mid = min(z_mid, len(rr[\"T_F\"]) - 1)\n\n    return dict(m_dot=m_dot, riser=rr, T_out_chimney=T_out_ch,\n                dp_buoy=dp_b, dp_fric=dp_f, dp_details=dp_details,\n                Q_electric=Q_electric, Q_net=Q_net, f_loss=f_loss,\n                Q_dura=Q_dura, Q_super=Q_super,\n                T_plate_mid=rr[\"T_plate\"][z_mid], T_F_mid=rr[\"T_F\"][z_mid],\n                T_S_mid=rr[\"T_S\"][z_mid], T_R_mid=rr[\"T_R\"][z_mid],\n                idx_mid=z_mid, T_amb=T_amb, T_inlet=T_inlet, wind=wind_speed)\n","numLines":50,"startLine":333,"totalLines":399}}}
