{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01Ve1WosoE9uA4uBDq4WHVTP","type":"message","role":"assistant","content":[{"type":"text","text":"While the sweep runs, I'm reviewing the reactivity mapping — and I've caught an important correction. I'm using the fuel-lattice k_inf (~1.5) as a proxy, but the physical feedback for point kinetics is the *core* reactivity change, which under a temperature-independent rod/leakage multiplier is Δρ_core(T) = 1 − k_inf(T_op)/k_inf(T), and the coefficient is (1/k)(dk/dT), not (1/k²)(dk/dT). My code had an extra factor of 1/k (~0.67), underestimating feedback by ~33%. Let me fix both files."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":867,"cache_read_input_tokens":138891,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":867},"output_tokens":2,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"bf29c1b0-7e93-43a9-86fb-8820c5d1c99e","uuid":"a2420805-e5ef-46e5-97ae-5a1b057388b0","request_id":"req_011Cce2XFDZvGFo5UiCYw4db"}
{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01Ve1WosoE9uA4uBDq4WHVTP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016xXBkeX2azUeNnuE5j1Lov","name":"Edit","input":{"replace_all":false,"file_path":"/root/bench/httr/transient.py","old_string":"def make_drho(Tk, kk, Top):\n    \"\"\"Reactivity change vs T relative to operating temp Top, from k_inf(T).\"\"\"\n    kfun = interp1d(Tk, kk, kind='quadratic', fill_value='extrapolate')\n    kop = float(kfun(Top))\n    def drho(T):\n        kT = float(kfun(np.clip(T, Tk.min()-200, Tk.max()+400)))\n        return (kT - kop)/(kT*kop)\n    return drho, kfun","new_string":"def make_drho(Tk, kk, Top):\n    \"\"\"Core reactivity change vs T relative to operating temp Top, from k_inf(T).\n    Under a temperature-independent control-rod/leakage multiplier M (rods frozen)\n    that makes the core critical at Top, k_eff(T)=k_inf(T)/k_inf(Top), so\n    Drho_core(T)=(k_eff-1)/k_eff = 1 - k_inf(Top)/k_inf(T).  (Note: one power of k,\n    not k^2 -- the constant multiplier cancels in the logarithmic derivative.)\"\"\"\n    kfun = interp1d(Tk, kk, kind='quadratic', fill_value='extrapolate')\n    kop = float(kfun(Top))\n    def drho(T):\n        kT = float(kfun(np.clip(T, Tk.min()-200, Tk.max()+400)))\n        return 1.0 - kop/kT\n    return drho, kfun"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":867,"cache_read_input_tokens":138891,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":867},"output_tokens":2,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"bf29c1b0-7e93-43a9-86fb-8820c5d1c99e","uuid":"036ec722-3cf5-41e7-98a8-d2312871db9c","request_id":"req_011Cce2XFDZvGFo5UiCYw4db"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016xXBkeX2azUeNnuE5j1Lov","type":"tool_result","content":"The file /root/bench/httr/transient.py has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"bf29c1b0-7e93-43a9-86fb-8820c5d1c99e","uuid":"fae28c39-595b-4db3-b30e-2516d2bbc912","timestamp":"2026-07-02T22:35:30.638Z","tool_use_result":{"filePath":"/root/bench/httr/transient.py","oldString":"def make_drho(Tk, kk, Top):\n    \"\"\"Reactivity change vs T relative to operating temp Top, from k_inf(T).\"\"\"\n    kfun = interp1d(Tk, kk, kind='quadratic', fill_value='extrapolate')\n    kop = float(kfun(Top))\n    def drho(T):\n        kT = float(kfun(np.clip(T, Tk.min()-200, Tk.max()+400)))\n        return (kT - kop)/(kT*kop)\n    return drho, kfun","newString":"def make_drho(Tk, kk, Top):\n    \"\"\"Core reactivity change vs T relative to operating temp Top, from k_inf(T).\n    Under a temperature-independent control-rod/leakage multiplier M (rods frozen)\n    that makes the core critical at Top, k_eff(T)=k_inf(T)/k_inf(Top), so\n    Drho_core(T)=(k_eff-1)/k_eff = 1 - k_inf(Top)/k_inf(T).  (Note: one power of k,\n    not k^2 -- the constant multiplier cancels in the logarithmic derivative.)\"\"\"\n    kfun = interp1d(Tk, kk, kind='quadratic', fill_value='extrapolate')\n    kop = float(kfun(Top))\n    def drho(T):\n        kT = float(kfun(np.clip(T, Tk.min()-200, Tk.max()+400)))\n        return 1.0 - kop/kT\n    return drho, kfun","originalFile":"\"\"\"\nHTTR LOFC coupled transient: point kinetics + fission-product decay heat +\n2-node lumped graphite thermal model (active core + reflector) + VCS heat sink.\n\nReactivity feedback is driven by the OpenMC-computed k_inf(T) curve\n(runs/main/keff.csv): the change in reactivity from the operating temperature,\nDrho(T) = (k(T) - k(Top)) / (k(T)*k(Top)).\n\nScenario: at t=0 the reactor is critical at 9 MWt (rods frozen); all He\ncirculators trip (no forced convection); VCS running. No scram.\n\nEverything the transient needs that is neutronics is COMPUTED (k_inf(T), beta_eff);\nthermal parameters are engineering estimates from public design data (see sources.md),\ncarried with a sensitivity analysis.\n\"\"\"\nimport numpy as np\nfrom scipy.integrate import solve_ivp\nfrom scipy.interpolate import interp1d\nimport csv, sys\n\n# ----------------------------------------------------------------------\n# 1. Graphite specific heat Cp(T)  [J/kg/K]  (nuclear graphite, standard)\n#    Butland-Maddison-like fit; ~710 @300K, ~1700 @1000K, ~2000 @2000K.\ndef cp_graphite(T):\n    # T in K. Piecewise-smooth fit to standard nuclear-graphite Cp.\n    # Butland & Maddison (1973) correlation for graphite:\n    # Cp = 4184*(0.54212 - 2.42667e-6*T - 90.2725/T - 43449.3/T^2\n    #            + 1.59309e7/T^3 - 1.43688e9/T^4)  [J/kg/K], T in K\n    T = np.clip(T, 200.0, 3000.0)\n    cp = 4184.0*(0.54212 - 2.42667e-6*T - 90.2725/T - 43449.3/T**2\n                 + 1.59309e7/T**3 - 1.43688e9/T**4)\n    return np.clip(cp, 400.0, 2200.0)\n\n# ----------------------------------------------------------------------\n# 2. Fission-product decay heat  P_d(t)/P0  (fraction of pre-trip fission power)\n#    Todreas-Kazimi / Wigner-Way form for finite operating time t_op (s).\ndef decay_frac(t, t_op):\n    t = np.maximum(t, 1e-3)\n    return 0.066*((t)**-0.2 - (t + t_op)**-0.2)\n\n# ----------------------------------------------------------------------\n# 3. Delayed-neutron 6-group data (U-235 thermal, Keepin) — group SHAPE.\n#    Absolute beta_eff is scaled to the OpenMC-computed value.\nBETA_I = np.array([0.000215,0.001424,0.001274,0.002568,0.000748,0.000273])\nLAM_I  = np.array([0.0124,0.0305,0.111,0.301,1.14,3.01])\nBETA0  = BETA_I.sum()   # ~0.0065\n\n# ----------------------------------------------------------------------\ndef load_kT(csv_path='runs/main/keff.csv', bp=1):\n    T, k, s = [], [], []\n    with open(csv_path) as f:\n        for row in csv.DictReader(f):\n            if int(row['bp']) == bp and int(row['prompt_only']) == 0:\n                T.append(float(row['T_K'])); k.append(float(row['keff']))\n                s.append(float(row['keff_sigma']))\n    idx = np.argsort(T)\n    return np.array(T)[idx], np.array(k)[idx], np.array(s)[idx]\n\ndef make_drho(Tk, kk, Top):\n    \"\"\"Reactivity change vs T relative to operating temp Top, from k_inf(T).\"\"\"\n    kfun = interp1d(Tk, kk, kind='quadratic', fill_value='extrapolate')\n    kop = float(kfun(Top))\n    def drho(T):\n        kT = float(kfun(np.clip(T, Tk.min()-200, Tk.max()+400)))\n        return (kT - kop)/(kT*kop)\n    return drho, kfun\n\n# ----------------------------------------------------------------------\ndef run(params, drho, beta_eff, verbose=False):\n    p = params\n    Top   = p['Top']          # operating core-avg graphite temp [K]\n    P0    = p['P0']           # pre-trip fission power [W] (9 MW)\n    Mc    = p['Mc']; Mr = p['Mr']   # graphite masses [kg]\n    Gcr   = p['Gcr']          # core<->reflector conductance [W/K]\n    Q0    = p['Q0']           # reflector->sink removal at T=Top [W]\n    Ts    = p['Ts']           # ultimate sink temp [K]\n    pexp  = p['pexp']         # exponent of removal law\n    t_op  = p['t_op']         # prior operating time [s] for decay heat\n    Lam   = p['Lam']          # prompt neutron generation time [s]\n\n    beta_i = BETA_I*(beta_eff/BETA0)\n    b_eff  = beta_i.sum()\n    # intrinsic neutron source (spontaneous fission of U-238 + (a,n)); tiny.\n    # Result is insensitive to its magnitude (only sharpens the power revival).\n    S = p.get('S', 1e-6)*P0\n\n    def Qout(Tr):\n        return Q0*np.maximum((Tr-Ts)/(Top-Ts), 0.0)**pexp\n\n    # initial precursors for steady P0\n    C0 = beta_i/(LAM_I*Lam)*P0\n    y0 = np.concatenate([[P0], C0, [Top, Top]])   # P, C1..6, Tc, Tr\n\n    def rhs(t, y):\n        P = max(y[0], 0.0)\n        C = np.maximum(y[1:7], 0.0)\n        Tc, Tr = y[7], y[8]\n        rho = drho(Tc)\n        dP = (rho - b_eff)/Lam*P + np.dot(LAM_I, C) + S\n        dC = beta_i/Lam*P - LAM_I*C\n        Pd = decay_frac(t, t_op)*P0\n        # heat balances\n        qcr = Gcr*(Tc - Tr)\n        dTc = (P + Pd - qcr)/(Mc*cp_graphite(Tc))\n        dTr = (qcr - Qout(Tr))/(Mr*cp_graphite(Tr))\n        return np.concatenate([[dP], dC, [dTc, dTr]])\n\n    t_end = p.get('t_end', 3.5*24*3600)\n    teval = np.unique(np.concatenate([np.linspace(0,600,200),\n                                      np.linspace(600, t_end, 4000)]))\n    sol = solve_ivp(rhs, (0, t_end), y0, method='BDF', t_eval=teval,\n                    rtol=1e-6, atol=[1e-2]+[1e-2]*6+[1e-3,1e-3], max_step=60.0)\n    return sol, b_eff\n\ndef summarize(sol, P0, Top, drho=None):\n    t = sol.t; P = sol.y[0]; Tc = sol.y[7]; Tr = sol.y[8]\n    # power minimum in first phase (first 30 min) -> initial collapse depth\n    i30 = max(np.searchsorted(t, 1800), 3)\n    Pmin_early = P[:i30].min()\n    tmin = t[:i30][np.argmin(P[:i30])]\n    # peak core temperature and its time\n    ipk = np.argmax(Tc); Tc_peak = Tc[ipk]; tpeak = t[ipk]\n    # recriticality: after the Tc peak, first time Tc cools back to Top\n    # (feedback reactivity returns to zero, rods frozen). Linear-interpolate.\n    trec = None\n    for i in range(max(ipk,1), len(t)):\n        if Tc[i] <= Top:\n            t0,t1 = t[i-1], t[i]; y0,y1 = Tc[i-1]-Top, Tc[i]-Top\n            trec = t0 + (t1-t0)*(y0/(y0-y1)) if y1 != y0 else t1\n            break\n    # stabilized fission power: mean over the last 10% of the trace\n    n = max(int(0.1*len(t)), 5)\n    P_stab = np.mean(P[-n:])\n    return dict(Pmin_early=Pmin_early, tmin=tmin, trec=trec,\n                Tc_peak=Tc_peak, tpeak=tpeak, P_stab=P_stab,\n                Tc_end=Tc[-1], Tr_end=Tr[-1], P_end=P[-1])\n\nif __name__ == '__main__':\n    bp = int(sys.argv[1]) if len(sys.argv) > 1 else 1\n    Top = float(sys.argv[2]) if len(sys.argv) > 2 else 820.0\n    Tk, kk, sk = load_kT(bp=bp)\n    print(\"k_inf(T):\", list(zip(Tk, np.round(kk,5), np.round(sk,5))))\n    drho, kfun = make_drho(Tk, kk, Top)\n    # isothermal coefficient at a few T\n    for T in [400,600,800,1000,1200]:\n        a = (kfun(T+10)-kfun(T-10))/(20*kfun(T)**2)*1e5\n        print(f\"  alpha_iso({T}K) = {a:8.2f} pcm/K\")\n    beta_eff = float(sys.argv[3]) if len(sys.argv) > 3 else 0.0065\n    params = dict(Top=Top, P0=9e6, Mc=14000.0, Mr=40000.0, Gcr=3000.0,\n                  Q0=0.6e6, Ts=320.0, pexp=1.5, t_op=30*24*3600.0, Lam=1e-3,\n                  t_end=3.5*24*3600)\n    sol, beff = run(params, drho, beta_eff, verbose=True)\n    s = summarize(sol, params['P0'], Top)\n    print(\"beta_eff used:\", beff)\n    for k_,v in s.items():\n        print(f\"  {k_}: {v}\")\n","structuredPatch":[{"oldStart":57,"oldLines":12,"newStart":57,"newLines":16,"lines":["     return np.array(T)[idx], np.array(k)[idx], np.array(s)[idx]"," "," def make_drho(Tk, kk, Top):","-    \"\"\"Reactivity change vs T relative to operating temp Top, from k_inf(T).\"\"\"","+    \"\"\"Core reactivity change vs T relative to operating temp Top, from k_inf(T).","+    Under a temperature-independent control-rod/leakage multiplier M (rods frozen)","+    that makes the core critical at Top, k_eff(T)=k_inf(T)/k_inf(Top), so","+    Drho_core(T)=(k_eff-1)/k_eff = 1 - k_inf(Top)/k_inf(T).  (Note: one power of k,","+    not k^2 -- the constant multiplier cancels in the logarithmic derivative.)\"\"\"","     kfun = interp1d(Tk, kk, kind='quadratic', fill_value='extrapolate')","     kop = float(kfun(Top))","     def drho(T):","         kT = float(kfun(np.clip(T, Tk.min()-200, Tk.max()+400)))","-        return (kT - kop)/(kT*kop)","+        return 1.0 - kop/kT","     return drho, kfun"," "," # ----------------------------------------------------------------------"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01HcAifX3aqtSjLGG9iEfoVs","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EPhrmHeDGiWB5fSSnpBLPr","name":"Edit","input":{"replace_all":false,"file_path":"/root/bench/httr/analyze.py","old_string":"        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n        for j, T in enumerate(Tq):\n            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T)**2)*1e5","new_string":"        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n        for j, T in enumerate(Tq):\n            # isothermal reactivity coefficient of the critical core = (1/k) dk/dT\n            # (logarithmic derivative; rod/leakage multiplier cancels)\n            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T))*1e5"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6787,"cache_read_input_tokens":139758,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6787},"output_tokens":61,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"bf29c1b0-7e93-43a9-86fb-8820c5d1c99e","uuid":"315fe7f4-3410-421b-8771-4525a01f4beb","request_id":"req_011Cce2e3SqeBtQFZUJHrT9b"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EPhrmHeDGiWB5fSSnpBLPr","type":"tool_result","content":"The file /root/bench/httr/analyze.py has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"bf29c1b0-7e93-43a9-86fb-8820c5d1c99e","uuid":"bda74ca8-b2c2-4eee-b24f-6a4ba0e44a3d","timestamp":"2026-07-02T22:35:35.768Z","tool_use_result":{"filePath":"/root/bench/httr/analyze.py","oldString":"        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n        for j, T in enumerate(Tq):\n            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T)**2)*1e5","newString":"        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n        for j, T in enumerate(Tq):\n            # isothermal reactivity coefficient of the critical core = (1/k) dk/dT\n            # (logarithmic derivative; rod/leakage multiplier cancels)\n            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T))*1e5","originalFile":"\"\"\"\nFinal analysis: load OpenMC k_inf(T), compute isothermal temperature coefficient\nalpha(T) with uncertainty, run nominal LOFC transient + sensitivity study, and\nemit results (JSON) and a plot. Consumes runs/main/keff.csv (BP on).\n\"\"\"\nimport json, numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom scipy.interpolate import interp1d\nimport transient as TR\n\nRNG = np.random.default_rng(12345)\n\ndef alpha_curve(Tk, kk, sk, Tq):\n    \"\"\"alpha(T)=dk/dT/k^2 [pcm/K] with 1-sigma via Monte Carlo over k points.\"\"\"\n    N = 4000\n    a_samp = np.zeros((N, len(Tq)))\n    dk_samp = np.zeros(N)  # slope 294->1200 overall\n    for i in range(N):\n        kp = kk + RNG.normal(0, 1, len(kk))*sk\n        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n        for j, T in enumerate(Tq):\n            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T)**2)*1e5\n    return a_samp.mean(0), a_samp.std(0)\n\ndef main():\n    Tk, kk, sk = TR.load_kT('runs/main/keff.csv', bp=1)\n    print(\"k_inf(T):\")\n    for T,k,s in zip(Tk,kk,sk): print(f\"  {T:6.1f} K : {k:.5f} +/- {s:.5f}\")\n    Tq = np.array([400,600,800,1000,1200.])\n    am, asd = alpha_curve(Tk, kk, sk, Tq)\n    print(\"isothermal temperature coefficient alpha(T):\")\n    for T,a,s in zip(Tq,am,asd): print(f\"  alpha({T:.0f}K) = {a:7.2f} +/- {s:4.2f} pcm/K\")\n\n    # try beta_eff from prompt-only run if present\n    beta_eff = 0.0065\n    try:\n        import csv\n        with open('runs/kin/keff.csv') as f:\n            rows=list(csv.DictReader(f))\n        kk_full = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n                   for r in rows if int(r['prompt_only'])==0}\n        kk_pr   = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n                   for r in rows if int(r['prompt_only'])==1}\n        T0=list(kk_pr.keys())[0]\n        kf,sf=kk_full.get(T0,(None,None)); kp,sp=kk_pr[T0]\n        if kf:\n            beta_eff=1-kp/kf\n            bsig=beta_eff*np.hypot(sf/kf,sp/kp)\n            print(f\"beta_eff (prompt method @ {T0}K) = {beta_eff:.5f} +/- {bsig:.5f}\")\n    except FileNotFoundError:\n        print(\"beta_eff: prompt-only run not found; using 0.0065 (design-basis).\")\n\n    Top = 823.0   # core-avg graphite temp at 9 MW (30%), nominal ~550 C\n    drho, kfun = TR.make_drho(Tk, kk, Top)\n\n    base = dict(Top=Top, P0=9e6, Mc=14000.0, Mr=50000.0, Gcr=6000.0,\n                Q0=0.6e6, Ts=320.0, pexp=1.5, t_op=30*24*3600.0, Lam=1e-3,\n                t_end=5.0*24*3600, S=1e-6)\n    sol, beff = TR.run(base, drho, beta_eff)\n    s0 = TR.summarize(sol, base['P0'], Top, drho)\n    print(\"\\n=== NOMINAL transient ===\")\n    print(f\"  power min (first 30 min): {s0['Pmin_early']/1e3:.2f} kW at {s0['tmin']/60:.1f} min\")\n    print(f\"  peak core temp: {s0['Tc_peak']-273:.0f} C at {s0['tpeak']/3600:.2f} h\")\n    print(f\"  recriticality time: {s0['trec']/3600:.1f} h\" if s0['trec'] else \"  no recriticality\")\n    print(f\"  stabilized fission power: {s0['P_stab']/1e3:.0f} kW ({s0['P_stab']/base['P0']*100:.1f}% of pre-trip 9MW)\")\n\n    # ---------- Sensitivity study ----------\n    print(\"\\n=== SENSITIVITY (recriticality time, stab power, peak Tc) ===\")\n    grid = []\n    for Mr in [25000, 40000, 55000, 70000, 90000]:\n        for Q0 in [0.4e6, 0.6e6, 0.9e6]:\n            for pexp in [1.0, 1.5, 2.0]:\n                for Topv in [773., 823., 873.]:\n                    p = dict(base); p['Mr']=Mr; p['Q0']=Q0; p['pexp']=pexp; p['Top']=Topv\n                    dr,_ = TR.make_drho(Tk, kk, Topv)\n                    so,_ = TR.run(p, dr, beta_eff)\n                    ss = TR.summarize(so, p['P0'], Topv, dr)\n                    grid.append((Mr,Q0,pexp,Topv,\n                                 ss['trec']/3600 if ss['trec'] else np.nan,\n                                 ss['P_stab']/1e3, ss['Tc_peak']-273))\n    grid = np.array(grid)\n    trec = grid[:,4][~np.isnan(grid[:,4])]\n    pstab = grid[:,5]; tcpk = grid[:,6]\n    print(f\"  recriticality time: median {np.median(trec):.1f} h, \"\n          f\"range [{np.percentile(trec,10):.1f}, {np.percentile(trec,90):.1f}] h \"\n          f\"(min {trec.min():.1f}, max {trec.max():.1f})\")\n    print(f\"  stabilized power: median {np.median(pstab):.0f} kW, \"\n          f\"[{np.percentile(pstab,10):.0f}, {np.percentile(pstab,90):.0f}] kW\")\n    print(f\"  peak core temp: median {np.median(tcpk):.0f} C, \"\n          f\"[{np.percentile(tcpk,10):.0f}, {np.percentile(tcpk,90):.0f}] C, max {tcpk.max():.0f} C\")\n\n    # ---------- Plot ----------\n    fig, ax = plt.subplots(2,1, figsize=(8,7), sharex=True)\n    t = sol.t/3600\n    ax[0].plot(t, sol.y[0]/1e6, 'b'); ax[0].set_yscale('log')\n    ax[0].set_ylabel('Fission power (MW)'); ax[0].grid(True, which='both', alpha=.3)\n    ax[0].axhline(9,ls='--',c='gray',lw=.8); ax[0].set_ylim(1e-4,20)\n    if s0['trec']: ax[0].axvline(s0['trec']/3600, ls=':', c='r', label=f\"recrit {s0['trec']/3600:.1f} h\")\n    ax[0].legend(); ax[0].set_title('HTTR LOFC (9 MWt, all circulators trip, no scram, VCS on) — computed')\n    ax[1].plot(t, sol.y[7]-273, 'r', label='core graphite (feedback)')\n    ax[1].plot(t, sol.y[8]-273, 'orange', label='reflector')\n    ax[1].axhline(Top-273, ls='--', c='k', lw=.8, label=f'T_op {Top-273:.0f} C')\n    ax[1].set_ylabel('Temperature (C)'); ax[1].set_xlabel('Time (h)')\n    ax[1].grid(True, alpha=.3); ax[1].legend(); ax[1].set_xlim(0, 120)\n    fig.tight_layout(); fig.savefig('output/lofc_transient.png', dpi=110)\n    print(\"\\nsaved output/lofc_transient.png\")\n\n    out = dict(k_T={float(T):[float(k),float(s)] for T,k,s in zip(Tk,kk,sk)},\n               alpha_T={float(T):[float(a),float(s)] for T,a,s in zip(Tq,am,asd)},\n               beta_eff=float(beta_eff),\n               nominal=dict(Pmin_kW=float(s0['Pmin_early']/1e3),\n                            tmin_min=float(s0['tmin']/60),\n                            Tc_peak_C=float(s0['Tc_peak']-273),\n                            tpeak_h=float(s0['tpeak']/3600),\n                            trec_h=float(s0['trec']/3600) if s0['trec'] else None,\n                            Pstab_kW=float(s0['P_stab']/1e3)),\n               sens=dict(trec_h=[float(np.percentile(trec,10)),float(np.median(trec)),float(np.percentile(trec,90))],\n                         Pstab_kW=[float(np.percentile(pstab,10)),float(np.median(pstab)),float(np.percentile(pstab,90))],\n                         Tcpeak_C=[float(np.percentile(tcpk,10)),float(np.median(tcpk)),float(np.percentile(tcpk,90)),float(tcpk.max())]))\n    json.dump(out, open('output/results.json','w'), indent=2)\n    print(\"saved output/results.json\")\n\nif __name__ == '__main__':\n    main()\n","structuredPatch":[{"oldStart":21,"oldLines":7,"newStart":21,"newLines":9,"lines":["         kp = kk + RNG.normal(0, 1, len(kk))*sk","         f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')","         for j, T in enumerate(Tq):","-            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T)**2)*1e5","+            # isothermal reactivity coefficient of the critical core = (1/k) dk/dT","+            # (logarithmic derivative; rod/leakage multiplier cancels)","+            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T))*1e5","     return a_samp.mean(0), a_samp.std(0)"," "," def main():"]}],"userModified":false,"replaceAll":false}}
