}\n    s.source = openmc.IndependentSource(\n        space=openmc.stats.Box((-1.3,-1.3,0.0), (1.3,1.3,3.9)),\n        constraints={'fissionable': True})\n    if prompt_only:\n        s.create_delayed_neutrons = False\n    s.output = {'tallies': False}\n    s.export_to_xml()\n    openmc.run(openmc_exec='openmc', threads=8, output=True)\n    sp = openmc.StatePoint(f'statepoint.{inactive+active}.h5')\n    k = sp.keff\n    dt = time.time() - t0\n    sp.close()\n    os.chdir(base + '/..')  # back to project root (runs/ parent)\n    os.chdir(os.path.dirname(os.path.dirname(base)))\n    w.writerow([label, T, int(bp), int(prompt_only), k.n, k.s, npart, round(dt,1)])\n    fcsv.flush()\n    print(f\"[{label}] T={T}K bp={bp} po={prompt_only} k={k.n:.5f}+/-{k.s:.5f} ({dt:.0f}s)\",\n          flush=True)\nfcsv.close()\nprint(f\"SWEEP_DONE {label}\", flush=True)\n","structuredPatch":[],"originalFile":null,"userModified":false}}
