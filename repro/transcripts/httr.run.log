{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01X8RB2fSe4DrYCw2ZgTa99T","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AXqxrhrJVcehAt3KviKZNK","name":"Write","input":{"file_path":"/root/bench/httr/run_sweep.py","content":"\"\"\"Sweep isothermal temperatures, run OpenMC, record k_eff (+/- sigma) to CSV.\nUsage: python run_sweep.py <label> <particles> <inactive> <active> <bp:0|1> <T1,T2,...> [prompt_only:0|1]\n\"\"\"\nimport os, sys, csv, time\nimport numpy as np\nimport openmc\nimport model_httr as M\n\nlabel     = sys.argv[1]\nparticles = int(sys.argv[2])\ninactive  = int(sys.argv[3])\nactive    = int(sys.argv[4])\nbp        = bool(int(sys.argv[5]))\ntemps     = [float(x) for x in sys.argv[6].split(',')]\nprompt_only = bool(int(sys.argv[7])) if len(sys.argv) > 7 else False\n\nbase = os.path.abspath(f'runs/{label}')\nos.makedirs(base, exist_ok=True)\ncsv_path = os.path.join(base, 'keff.csv')\nnew = not os.path.exists(csv_path)\nfcsv = open(csv_path, 'a', newline='')\nw = csv.writer(fcsv)\nif new:\n    w.writerow(['label','T_K','bp','prompt_only','keff','keff_sigma','n_triso','seconds'])\n    fcsv.flush()\n\nfor T in temps:\n    wd = os.path.join(base, f'T{int(T)}{\"_p\" if prompt_only else \"\"}')\n    os.makedirs(wd, exist_ok=True)\n    os.chdir(wd)\n    t0 = time.time()\n    geom, mats, npart, rcell = M.build(temp=T, enrich=6.0, packing=0.30,\n                                       sab='c_Graphite', seed=1, bp=bp)\n    geom.export_to_xml(); mats.export_to_xml()\n    s = openmc.Settings()\n    s.run_mode = 'eigenvalue'\n    s.particles = particles\n    s.batches = inactive + active\n    s.inactive = inactive\n    s.temperature = {'method': 'interpolation', 'range': (250.0, 2500.0)}\n    s.source = openmc.IndependentSource(\n        space=openmc.stats.Box((-1.3,-1.3,0.0), (1.3,1.3,3.9)),\n        constraints={'fissionable': True})\n    if prompt_only:\n        s.create_delayed_neutrons = False\n    s.output = {'tallies': False}\n    s.export_to_xml()\n    openmc.run(openmc_exec='openmc', threads=8, output=True)\n    sp = openmc.StatePoint(f'statepoint.{inactive+active}.h5')\n    k = sp.keff\n    dt = time.time() - t0\n    sp.close()\n    os.chdir(base + '/..')  # back to project root (runs/ parent)\n    os.chdir(os.path.dirname(os.path.dirname(base)))\n    w.writerow([label, T, int(bp), int(prompt_only), k.n, k.s, npart, round(dt,1)])\n    fcsv.flush()\n    print(f\"[{label}] T={T}K bp={bp} po={prompt_only} k={k.n:.5f}+/-{k.s:.5f} ({dt:.0f}s)\",\n          flush=True)\nfcsv.close()\nprint(f\"SWEEP_DONE {label}\", flush=True)\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":283,"cache_read_input_tokens":91762,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":283},"output_tokens":6,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"bf29c1b0-7e93-43a9-86fb-8820c5d1c99e","uuid":"06028c37-72aa-40b6-afec-64795a668d70","request_id":"req_011Cce1fHCzDCWdyEjjK29fY"}
