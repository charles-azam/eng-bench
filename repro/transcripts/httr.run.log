{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KVVw1ztuPQdbgyEzZGPstm","type":"tool_result","content":"1\t\"\"\"\n2\tFinal analysis: load OpenMC k_inf(T), compute isothermal temperature coefficient\n3\talpha(T) with uncertainty, run nominal LOFC transient + sensitivity study, and\n4\temit results (JSON) and a plot. Consumes runs/main/keff.csv (BP on).\n5\t\"\"\"\n6\timport json, numpy as np\n7\timport matplotlib\n8\tmatplotlib.use('Agg')\n9\timport matplotlib.pyplot as plt\n10\tfrom scipy.interpolate import interp1d\n11\timport transient as TR\n12\t\n13\tRNG = np.random.default_rng(12345)\n14\t\n15\tdef alpha_curve(Tk, kk, sk, Tq):\n16\t    \"\"\"alpha(T)=dk/dT/k^2 [pcm/K] with 1-sigma via Monte Carlo over k points.\"\"\"\n17\t    N = 4000\n18\t    a_samp = np.zeros((N, len(Tq)))\n19\t    dk_samp = np.zeros(N)  # slope 294->1200 overall\n20\t    for i in range(N):\n21\t        kp = kk + RNG.normal(0, 1, len(kk))*sk\n22\t        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n23\t        for j, T in enumerate(Tq):\n24\t            # isothermal reactivity coefficient of the critical core = (1/k) dk/dT\n25\t            # (logarithmic derivative; rod/leakage multiplier cancels)\n26\t            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T))*1e5\n27\t    return a_samp.mean(0), a_samp.std(0)\n28\t\n29\tdef main():\n30\t    Tk, kk, sk = TR.load_kT('runs/main/keff.csv', bp=1)\n31\t    print(\"k_inf(T):\")\n32\t    for T,k,s in zip(Tk,kk,sk): print(f\"  {T:6.1f} K : {k:.5f} +/- {s:.5f}\")\n33\t    Tq = np.array([400,600,800,1000,1200.])\n34\t    am, asd = alpha_curve(Tk, kk, sk, Tq)\n35\t    print(\"isothermal temperature coefficient alpha(T):\")\n36\t    for T,a,s in zip(Tq,am,asd): print(f\"  alpha({T:.0f}K) = {a:7.2f} +/- {s:4.2f} pcm/K\")\n37\t\n38\t    # try beta_eff from prompt-only run if present\n39\t    beta_eff = 0.0065\n40\t    try:\n41\t        import csv\n42\t        with open('runs/kin/keff.csv') as f:\n43\t            rows=list(csv.DictReader(f))\n44\t        kk_full = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n45\t                   for r in rows if int(r['prompt_only'])==0}\n46\t        kk_pr   = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n47\t                   for r in rows if int(r['prompt_only'])==1}\n48\t        T0=list(kk_pr.keys())[0]\n49\t        kf,sf=kk_full.get(T0,(None,None)); kp,sp=kk_pr[T0]\n50\t        if kf:\n51\t            beta_eff=1-kp/kf\n52\t            bsig=beta_eff*np.hypot(sf/kf,sp/kp)\n53\t            print(f\"beta_eff (prompt method @ {T0}K) = {beta_eff:.5f} +/- {bsig:.5f}\")\n54\t    except FileNotFoundError:\n55\t        print(\"beta_eff: prompt-only run not found; using 0.0065 (design-basis).\")\n56\t\n57\t    Top = 823.0   # core-avg graphite temp at 9 MW (30%), nominal ~550 C\n58\t    drho, kfun = TR.make_drho(Tk, kk, Top)\n59\t\n60\t    # Nominal thermal parameters. Gcr/Grv are geometry-informed: radial graphite\n61\t    # conduction (k~40 W/m/K, core r~1.15 m, H=2.9 m) gives core->reflector\n62\t    # conductance of order 1-3 kW/K; reflector->vessel similar (conduction+gap\n63\t    # radiation). L0 is the passive (non-coolant) heat leak at the 30%-power test\n64\t    # condition, ~0.3 MW (< the 0.6 MW full-power VCS rating). See sources.md.\n65\t    base = dict(Top=Top, P0=9e6, Mc=14000.0, Mr=45000.0, Mv=100000.0,\n66\t                Gcr=2000.0, Grv=2500.0, Q0=0.3e6, L0=0.3e6,\n67\t                Ts=320.0, pexp=1.5, t_op=30*24*3600.0, Lam=1e-3,\n68\t                t_end=6.0*24*3600, S=1e-6)\n69\t    sol, beff = TR.run(base, drho, beta_eff)\n70\t    s0 = TR.summarize(sol, base['P0'], Top, drho)\n71\t    print(\"\\n=== NOMINAL transient ===\")\n72\t    print(f\"  power min (first 30 min): {s0['Pmin_early']/1e3:.2f} kW at {s0['tmin']/60:.1f} min\")\n73\t    print(f\"  peak core temp: {s0['Tc_peak']-273:.0f} C at {s0['tpeak']/3600:.2f} h\")\n74\t    print(f\"  recriticality time: {s0['trec']/3600:.1f} h\" if s0['trec'] else \"  no recriticality\")\n75\t    print(f\"  stabilized fission power: {s0['P_stab']/1e3:.0f} kW ({s0['P_stab']/base['P0']*100:.1f}% of pre-trip 9MW)\")\n76\t    print(f\"  peak vessel temp: {s0['Tv_peak']-273:.0f} C (end {s0['Tv_end']-273:.0f} C)\")\n77\t\n78\t    # ---------- Sensitivity study (randomized over uncertain thermal params) ----------\n79\t    print(\"\\n=== SENSITIVITY (random sample over thermal parameters) ===\")\n80\t    NS = 400\n81\t    rows = []\n82\t    for _ in range(NS):\n83\t        Mc  = RNG.uniform(10000, 20000)\n84\t        Mr  = RNG.uniform(25000, 90000)     # responsive reflector graphite\n85\t        Gcr = RNG.uniform(3000, 12000)      # core<->reflector conductance\n86\t        Grv = RNG.uniform(2000, 8000)       # reflector<->vessel conductance\n87\t        L0  = RNG.uniform(0.3e6, 0.9e6)     # passive leak / VCS capacity\n88\t        pexp= RNG.uniform(1.0, 2.5)\n89\t        Topv= RNG.uniform(753., 893.)       # core-avg graphite temp at 9 MW\n90\t        top = RNG.uniform(3, 60)*24*3600.   # prior operating time\n91\t        p = dict(base); p.update(Mc=Mc,Mr=Mr,Gcr=Gcr,Grv=Grv,Q0=L0,L0=L0,\n92\t                                 pexp=pexp,Top=Topv,t_op=top)\n93\t        dr,_ = TR.make_drho(Tk, kk, Topv)\n94\t        try:\n95\t            so,_ = TR.run(p, dr, beta_eff)\n96\t            ss = TR.summarize(so, p['P0'], Topv, dr)\n97\t            rows.append((ss['trec']/3600 if ss['trec'] else np.nan,\n98\t                         ss['P_stab']/1e3, ss['Tc_peak']-273, ss['Tv_peak']-273))\n99\t        except Exception:\n100\t            continue\n101\t    G = np.array(rows)\n102\t    trec = G[:,0][~np.isnan(G[:,0])]; pstab=G[:,1]; tcpk=G[:,2]; tvpk=G[:,3]\n103\t    pc = lambda a,q: float(np.percentile(a,q))\n104\t    print(f\"  recriticality time: median {np.median(trec):.1f} h, \"\n105\t          f\"P10-P90 [{pc(trec,10):.1f}, {pc(trec,90):.1f}] h (min {trec.min():.1f}, max {trec.max():.1f})\")\n106\t    print(f\"  stabilized fission power: median {np.median(pstab):.0f} kW, \"\n107\t          f\"[{pc(pstab,10):.0f}, {pc(pstab,90):.0f}] kW\")\n108\t    print(f\"  peak core graphite temp: median {np.median(tcpk):.0f} C, \"\n109\t          f\"[{pc(tcpk,10):.0f}, {pc(tcpk,90):.0f}] C, max {tcpk.max():.0f} C\")\n110\t    print(f\"  peak vessel temp: median {np.median(tvpk):.0f} C, max {tvpk.max():.0f} C\")\n111\t\n112\t    # ---------- Plot ----------\n113\t    fig, ax = plt.subplots(2,1, figsize=(8,7), sharex=True)\n114\t    t = sol.t/3600\n115\t    ax[0].plot(t, sol.y[0]/1e6, 'b'); ax[0].set_yscale('log')\n116\t    ax[0].set_ylabel('Fission power (MW)'); ax[0].grid(True, which='both', alpha=.3)\n117\t    ax[0].axhline(9,ls='--',c='gray',lw=.8); ax[0].set_ylim(1e-4,20)\n118\t    if s0['trec']: ax[0].axvline(s0['trec']/3600, ls=':', c='r', label=f\"recrit {s0['trec']/3600:.1f} h\")\n119\t    ax[0].legend(); ax[0].set_title('HTTR LOFC (9 MWt, all circulators trip, no scram, VCS on) — computed')\n120\t    ax[1].plot(t, sol.y[7]-273, 'r', label='core graphite (feedback)')\n121\t    ax[1].plot(t, sol.y[8]-273, 'orange', label='reflector')\n122\t    ax[1].plot(t, sol.y[9]-273, 'green', label='vessel (RPV)')\n123\t    ax[1].axhline(Top-273, ls='--', c='k', lw=.8, label=f'T_op {Top-273:.0f} C')\n124\t    ax[1].set_ylabel('Temperature (C)'); ax[1].set_xlabel('Time (h)')\n125\t    ax[1].grid(True, alpha=.3); ax[1].legend(); ax[1].set_xlim(0, 120)\n126\t    fig.tight_layout(); fig.savefig('output/lofc_transient.png', dpi=110)\n127\t    print(\"\\nsaved output/lofc_transient.png\")\n128\t\n129\t    out = dict(k_T={float(T):[float(k),float(s)] for T,k,s in zip(Tk,kk,sk)},\n130\t               alpha_T={float(T):[float(a),float(s)] for T,a,s in zip(Tq,am,asd)},\n131\t               beta_eff=float(beta_eff),\n132\t               nominal=dict(Pmin_kW=float(s0['Pmin_early']/1e3),\n133\t                            tmin_min=float(s0['tmin']/60),\n134\t                            Tc_peak_C=float(s0['Tc_peak']-273),\n135\t                            tpeak_h=float(s0['tpeak']/3600),\n136\t                            trec_h=float(s0['trec']/3600) if s0['trec'] else None,\n137\t                            Pstab_kW=float(s0['P_stab']/1e3),\n138\t                            Tv_peak_C=float(s0['Tv_peak']-273),\n139\t                            Tv_end_C=float(s0['Tv_end']-273)),\n140\t               sens=dict(trec_h=[pc(trec,10),float(np.median(trec)),pc(trec,90),float(trec.min()),float(trec.max())],\n141\t                         Pstab_kW=[pc(pstab,10),float(np.median(pstab)),pc(pstab,90)],\n142\t                         Tcpeak_C=[pc(tcpk,10),float(np.median(tcpk)),pc(tcpk,90),float(tcpk.max())],\n143\t                         Tvpeak_C=[float(np.median(tvpk)),float(tvpk.max())]))\n144\t    json.dump(out, open('output/results.json','w'), indent=2)\n145\t    print(\"saved output/results.json\")\n146\t\n147\tif __name__ == '__main__':\n148\t    main()\n149\t"}]},"parent_tool_use_id":null,"session_id":"77b54c61-43fb-495b-8ed2-3da7396dea8b","uuid":"50f31882-1b4e-4098-92d6-5bff83812107","timestamp":"2026-07-03T07:45:39.140Z","tool_use_result":{"type":"text","file":{"filePath":"/root/bench/httr/analyze.py","content":"\"\"\"\nFinal analysis: load OpenMC k_inf(T), compute isothermal temperature coefficient\nalpha(T) with uncertainty, run nominal LOFC transient + sensitivity study, and\nemit results (JSON) and a plot. Consumes runs/main/keff.csv (BP on).\n\"\"\"\nimport json, numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom scipy.interpolate import interp1d\nimport transient as TR\n\nRNG = np.random.default_rng(12345)\n\ndef alpha_curve(Tk, kk, sk, Tq):\n    \"\"\"alpha(T)=dk/dT/k^2 [pcm/K] with 1-sigma via Monte Carlo over k points.\"\"\"\n    N = 4000\n    a_samp = np.zeros((N, len(Tq)))\n    dk_samp = np.zeros(N)  # slope 294->1200 overall\n    for i in range(N):\n        kp = kk + RNG.normal(0, 1, len(kk))*sk\n        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n        for j, T in enumerate(Tq):\n            # isothermal reactivity coefficient of the critical core = (1/k) dk/dT\n            # (logarithmic derivative; rod/leakage multiplier cancels)\n            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T))*1e5\n    return a_samp.mean(0), a_samp.std(0)\n\ndef main():\n    Tk, kk, sk = TR.load_kT('runs/main/keff.csv', bp=1)\n    print(\"k_inf(T):\")\n    for T,k,s in zip(Tk,kk,sk): print(f\"  {T:6.1f} K : {k:.5f} +/- {s:.5f}\")\n    Tq = np.array([400,600,800,1000,1200.])\n    am, asd = alpha_curve(Tk, kk, sk, Tq)\n    print(\"isothermal temperature coefficient alpha(T):\")\n    for T,a,s in zip(Tq,am,asd): print(f\"  alpha({T:.0f}K) = {a:7.2f} +/- {s:4.2f} pcm/K\")\n\n    # try beta_eff from prompt-only run if present\n    beta_eff = 0.0065\n    try:\n        import csv\n        with open('runs/kin/keff.csv') as f:\n            rows=list(csv.DictReader(f))\n        kk_full = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n                   for r in rows if int(r['prompt_only'])==0}\n        kk_pr   = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n                   for r in rows if int(r['prompt_only'])==1}\n        T0=list(kk_pr.keys())[0]\n        kf,sf=kk_full.get(T0,(None,None)); kp,sp=kk_pr[T0]\n        if kf:\n            beta_eff=1-kp/kf\n            bsig=beta_eff*np.hypot(sf/kf,sp/kp)\n            print(f\"beta_eff (prompt method @ {T0}K) = {beta_eff:.5f} +/- {bsig:.5f}\")\n    except FileNotFoundError:\n        print(\"beta_eff: prompt-only run not found; using 0.0065 (design-basis).\")\n\n    Top = 823.0   # core-avg graphite temp at 9 MW (30%), nominal ~550 C\n    drho, kfun = TR.make_drho(Tk, kk, Top)\n\n    # Nominal thermal parameters. Gcr/Grv are geometry-informed: radial graphite\n    # conduction (k~40 W/m/K, core r~1.15 m, H=2.9 m) gives core->reflector\n    # conductance of order 1-3 kW/K; reflector->vessel similar (conduction+gap\n    # radiation). L0 is the passive (non-coolant) heat leak at the 30%-power test\n    # condition, ~0.3 MW (< the 0.6 MW full-power VCS rating). See sources.md.\n    base = dict(Top=Top, P0=9e6, Mc=14000.0, Mr=45000.0, Mv=100000.0,\n                Gcr=2000.0, Grv=2500.0, Q0=0.3e6, L0=0.3e6,\n                Ts=320.0, pexp=1.5, t_op=30*24*3600.0, Lam=1e-3,\n                t_end=6.0*24*3600, S=1e-6)\n    sol, beff = TR.run(base, drho, beta_eff)\n    s0 = TR.summarize(sol, base['P0'], Top, drho)\n    print(\"\\n=== NOMINAL transient ===\")\n    print(f\"  power min (first 30 min): {s0['Pmin_early']/1e3:.2f} kW at {s0['tmin']/60:.1f} min\")\n    print(f\"  peak core temp: {s0['Tc_peak']-273:.0f} C at {s0['tpeak']/3600:.2f} h\")\n    print(f\"  recriticality time: {s0['trec']/3600:.1f} h\" if s0['trec'] else \"  no recriticality\")\n    print(f\"  stabilized fission power: {s0['P_stab']/1e3:.0f} kW ({s0['P_stab']/base['P0']*100:.1f}% of pre-trip 9MW)\")\n    print(f\"  peak vessel temp: {s0['Tv_peak']-273:.0f} C (end {s0['Tv_end']-273:.0f} C)\")\n\n    # ---------- Sensitivity study (randomized over uncertain thermal params) ----------\n    print(\"\\n=== SENSITIVITY (random sample over thermal parameters) ===\")\n    NS = 400\n    rows = []\n    for _ in range(NS):\n        Mc  = RNG.uniform(10000, 20000)\n        Mr  = RNG.uniform(25000, 90000)     # responsive reflector graphite\n        Gcr = RNG.uniform(3000, 12000)      # core<->reflector conductance\n        Grv = RNG.uniform(2000, 8000)       # reflector<->vessel conductance\n        L0  = RNG.uniform(0.3e6, 0.9e6)     # passive leak / VCS capacity\n        pexp= RNG.uniform(1.0, 2.5)\n        Topv= RNG.uniform(753., 893.)       # core-avg graphite temp at 9 MW\n        top = RNG.uniform(3, 60)*24*3600.   # prior operating time\n        p = dict(base); p.update(Mc=Mc,Mr=Mr,Gcr=Gcr,Grv=Grv,Q0=L0,L0=L0,\n                                 pexp=pexp,Top=Topv,t_op=top)\n        dr,_ = TR.make_drho(Tk, kk, Topv)\n        try:\n            so,_ = TR.run(p, dr, beta_eff)\n            ss = TR.summarize(so, p['P0'], Topv, dr)\n            rows.append((ss['trec']/3600 if ss['trec'] else np.nan,\n                         ss['P_stab']/1e3, ss['Tc_peak']-273, ss['Tv_peak']-273))\n        except Exception:\n            continue\n    G = np.array(rows)\n    trec = G[:,0][~np.isnan(G[:,0])]; pstab=G[:,1]; tcpk=G[:,2]; tvpk=G[:,3]\n    pc = lambda a,q: float(np.percentile(a,q))\n    print(f\"  recriticality time: median {np.median(trec):.1f} h, \"\n          f\"P10-P90 [{pc(trec,10):.1f}, {pc(trec,90):.1f}] h (min {trec.min():.1f}, max {trec.max():.1f})\")\n    print(f\"  stabilized fission power: median {np.median(pstab):.0f} kW, \"\n          f\"[{pc(pstab,10):.0f}, {pc(pstab,90):.0f}] kW\")\n    print(f\"  peak core graphite temp: median {np.median(tcpk):.0f} C, \"\n          f\"[{pc(tcpk,10):.0f}, {pc(tcpk,90):.0f}] C, max {tcpk.max():.0f} C\")\n    print(f\"  peak vessel temp: median {np.median(tvpk):.0f} C, max {tvpk.max():.0f} C\")\n\n    # ---------- Plot ----------\n    fig, ax = plt.subplots(2,1, figsize=(8,7), sharex=True)\n    t = sol.t/3600\n    ax[0].plot(t, sol.y[0]/1e6, 'b'); ax[0].set_yscale('log')\n    ax[0].set_ylabel('Fission power (MW)'); ax[0].grid(True, which='both', alpha=.3)\n    ax[0].axhline(9,ls='--',c='gray',lw=.8); ax[0].set_ylim(1e-4,20)\n    if s0['trec']: ax[0].axvline(s0['trec']/3600, ls=':', c='r', label=f\"recrit {s0['trec']/3600:.1f} h\")\n    ax[0].legend(); ax[0].set_title('HTTR LOFC (9 MWt, all circulators trip, no scram, VCS on) — computed')\n    ax[1].plot(t, sol.y[7]-273, 'r', label='core graphite (feedback)')\n    ax[1].plot(t, sol.y[8]-273, 'orange', label='reflector')\n    ax[1].plot(t, sol.y[9]-273, 'green', label='vessel (RPV)')\n    ax[1].axhline(Top-273, ls='--', c='k', lw=.8, label=f'T_op {Top-273:.0f} C')\n    ax[1].set_ylabel('Temperature (C)'); ax[1].set_xlabel('Time (h)')\n    ax[1].grid(True, alpha=.3); ax[1].legend(); ax[1].set_xlim(0, 120)\n    fig.tight_layout(); fig.savefig('output/lofc_transient.png', dpi=110)\n    print(\"\\nsaved output/lofc_transient.png\")\n\n    out = dict(k_T={float(T):[float(k),float(s)] for T,k,s in zip(Tk,kk,sk)},\n               alpha_T={float(T):[float(a),float(s)] for T,a,s in zip(Tq,am,asd)},\n               beta_eff=float(beta_eff),\n               nominal=dict(Pmin_kW=float(s0['Pmin_early']/1e3),\n                            tmin_min=float(s0['tmin']/60),\n                            Tc_peak_C=float(s0['Tc_peak']-273),\n                            tpeak_h=float(s0['tpeak']/3600),\n                            trec_h=float(s0['trec']/3600) if s0['trec'] else None,\n                            Pstab_kW=float(s0['P_stab']/1e3),\n                            Tv_peak_C=float(s0['Tv_peak']-273),\n                            Tv_end_C=float(s0['Tv_end']-273)),\n               sens=dict(trec_h=[pc(trec,10),float(np.median(trec)),pc(trec,90),float(trec.min()),float(trec.max())],\n                         Pstab_kW=[pc(pstab,10),float(np.median(pstab)),pc(pstab,90)],\n                         Tcpeak_C=[pc(tcpk,10),float(np.median(tcpk)),pc(tcpk,90),float(tcpk.max())],\n                         Tvpeak_C=[float(np.median(tvpk)),float(tvpk.max())]))\n    json.dump(out, open('output/results.json','w'), indent=2)\n    print(\"saved output/results.json\")\n\nif __name__ == '__main__':\n    main()\n","numLines":149,"startLine":1,"totalLines":149}}}
