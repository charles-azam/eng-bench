{"type":"assistant","message":{"model":"claude-sonnet-5","id":"msg_01Ua1VcHf29WS4i6aL3JaNHu","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WoHgk46YM548MaspXBNN5c","name":"Edit","input":{"replace_all":false,"file_path":"/root/bench/triso_sonnet/output/main.py","old_string":"    # onset time: first point in the trace where driving stress reaches 90% of its peak\n    onset_time_h, onset_T = None, None\n    for (th, TC, PMPa, sp, sth) in trace:\n        if (sp + sth) >= 0.9 * peak_sigma_net:\n            onset_time_h, onset_T = th, TC\n            break","new_string":"    # Onset time: restrict to the FINAL hold at the case's designated peak temperature (the\n    # \"case of interest\" per inputs/02_cases.md) to avoid locking onto a transient stress spike\n    # during an earlier intermediate excursion in staged schedules (e.g. A1's 1550C dwell before\n    # the drop-and-reheat to 1600C). Find the last contiguous run where T == peak_T, then find\n    # the first point within it reaching 90% of ITS local (within-window) maximum.\n    peak_T_target = case[\"peak_T\"]\n    final_window = []\n    for (th, TC, PMPa, sp, sth) in trace:\n        if abs(TC - peak_T_target) < 1.0:\n            final_window.append((th, TC, sp, sth))\n        elif final_window:\n            final_window = []  # reset: only keep the LAST contiguous run\n    window_peak = max(sp + sth for (_, _, sp, sth) in final_window) if final_window else peak_sigma_net\n    onset_time_h, onset_T = None, None\n    for (th, TC, sp, sth) in final_window:\n        if (sp + sth) >= 0.9 * window_peak:\n            onset_time_h, onset_T = th, TC\n            break\n    if onset_time_h is None:\n        onset_time_h, onset_T = peak_time_h, peak_T_at_peak"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":2504,"cache_read_input_tokens":173038,"cache_creation":{"ephemeral_5m_input_tokens":0,"ep