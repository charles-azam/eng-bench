f [1/K], ideal gas.\"\"\"\n    return 1.0 / T\n\ndef nu(T, P=P_ATM):\n    return mu(T) / rho(T, P)\n\nif __name__ == \"__main__\":\n    for Tc in [2, 20, 50, 100, 200, 300, 500]:\n        T = Tc + 273.15\n        print(f\"T={Tc:4d}C  rho={rho(T):.4f}  mu={mu(T):.3e}  k={k(T):.4f}  \"\n              f\"cp={cp(T):.1f}  Pr={Pr(T):.4f}\")\n","structuredPatch":[],"originalFile":null,"userModified":false}}
