 +=D_Cs_SiC(T)/G['r_m']**2*dt\n        tau_csk+=Dp_Cs_kernel(T)*dt\n        # pressure using gas released so far, at this T\n        F_g=F_release(tau_gas)\n        n_void=(Y_gas*Nf*F_g+Y_CO*Nf)/NA\n        P=n_void*R*K(T)/G['V_void']; sig_p=P*G['r_m']/(2*G['t'])/1e6\n        sig_net=sig_p-sigma_res(flu018,T); pf=Pf_sic(sig_net)\n        if pf>maxPf: maxPf=pf; peakP=P/1e6; peakS=sig_net\n        if pf*c['npart']>=0.5 and onset is None: onset=(T,dur)\n    nfail=maxPf*c['npart']\n    F_cs_intact=F_release(tau_cs)\n    F_gas_failed=F_release(tau_gas)\n    F_cs_failed =F_release(tau_csk)\n    ff=nfail/c['npart']\n    Kr=ff*F_gas_failed\n    Cs=ff*F_cs_failed+(1-ff)*F_cs_intact\n    summary.append((c['name'],nfail,Kr,Cs,peakP,peakS,maxPf,F_cs_intact))\n    print(f\"\\n--- {c['name']} ---  fissions/part={Nf:.3e}  void={G['V_void']:.2e} m^3\")\n    print(f\"  peak SiC net tension  ~ {peakS:.0f} MPa  (P~{peakP:.0f} MPa)\")\n    print(f\"  Weibull Pf/particle   = {maxPf:.2e}  -> E[N_fail]={nfail:.3f}/{c['npart']}\")\n    print(f\"  onset (Pf*N>=0.5)     = {onset}\")\n    print(f\"  tau_Cs,SiC={tau_cs:.3e}  Cs release via intact SiC = {F_cs_intact:.3f}\")\n    print(f\"  tau_gas={tau_gas:.3f} (F={F_gas_failed:.3f})  tau_Cs,kernel={tau_csk:.2f} (F={F_cs_failed:.3f})\")\n    print(f\"  ==> Kr-85  frac release = {Kr:.2e}   ({Kr/c['thr']*1 if False else nfail:.3f} equiv failed part.)\")\n    print(f\"  ==> Cs-137 frac release = {Cs:.3f}\")\n\nprint(\"\\n\"+\"=\"*90+\"\\nRANKING by Cs-137 release (severity):\")\nfor n,nf,kr,cs,pp,ps,pf,fi in sorted(summary,key=lambda x:-x[3]):\n    print(f\"  {n}: Cs={cs:.3f}  Kr={kr:.2e}  E[Nfail]={nf:.3f}\")\nprint(\"\\nRANKING by peak SiC failure probability:\")\nfor n,nf,kr,cs,pp,ps,pf,fi in sorted(summary,key=lambda x:-x[6]):\n    print(f\"  {n}: Pf/part={pf:.2e} E[Nfail]={nf:.3f}  peakNetStress={ps:.0f} MPa\")\n","structuredPatch":[{"oldStart":1,"oldLines":148,"newStart":1,"newLines":110,"lines":[" #!/usr/bin/env python3"," \"\"\""," TRISO accident-heating failure & release predictions (offline).","-All physics/correlations from inputs/03_material_properties.md (TECDOC-1674 annex).","-No external data used.","+All correlations from inputs/03_material_properties.md (TECDOC-1674 annex).","+Schedule-integrated model."," \"\"\""," import numpy as np","+from math import gamma"," ","-R = 8.314  # J/mol/K","-NA = 6.02214e23","+R = 8.314; NA = 6.02214e23"," def K(Tc): return Tc + 273.15"," ","-# ----------------------------------------------------------------------","-# Particle geometry per batch (um) -> m","-# ----------------------------------------------------------------------","-def geom(kernel_d, buffer, ipyc, sic, opyc, rho_buffer):","-    a = kernel_d/2 * 1e-6                 # kernel radius m","-    r_i = (kernel_d/2 + buffer + ipyc)*1e-6   # SiC inner radius","-    r_o = r_i + sic*1e-6                  # SiC outer radius","-    r_m = 0.5*(r_i+r_o)                   # SiC mean radius","-    t   = sic*1e-6                        # SiC thickness","-    # buffer void volume","-    rb_o = (kernel_d/2 + buffer)*1e-6","-    V_buffer = 4/3*np.pi*(rb_o**3 - a**3)","-    poros = 1 - rho_buffer/2.10           # theoretical PyC density ~2.10 Mg/m3","-    V_void = poros*V_buffer               # dominant void; kernel open porosity neglected","-    return dict(a=a, r_i=r_i, r_o=r_o, r_m=r_m, t=t, V_void=V_void, poros=poros)","+# ---------- geometry ----------","+def geom(kd, buf, ipyc, sic, opyc, rho_buf):","+    a=kd/2*1e-6; r_i=(kd/2+buf+ipyc)*1e-6; r_o=r_i+sic*1e-6","+    rb_o=(kd/2+buf)*1e-6","+    V=4/3*np.pi*(rb_o**3-a**3); poros=1-rho_buf/2.10","+    return dict(a=a,r_i=r_i,r_o=r_o,r_m=0.5*(r_i+r_o),t=sic*1e-6,V_void=poros*V,poros=poros)","+G_K3=geom(497,94,41,36,40,1.00); G_P4=G_K3; G_K6=geom(508,102,39,36,38,1.02)"," ","-# EUO2308 (K3, P4) and EUO2358 (K6)","-G_K3 = geom(497, 94, 41, 36, 40, 1.00)","-G_P4 = geom(497, 94, 41, 36, 40, 1.00)   # same batch 2308","-G_K6 = geom(508,102, 39, 36, 38, 1.02)","+# ---------- inventory ----------","+M_U=238.0; Y_gas=0.31; Y_CO=0.15","+def nHM(hm,npart): return (hm/npart)/M_U*NA"," ","-# ----------------------------------------------------------------------","-# Fission / gas inventory","-# ----------------------------------------------------------------------","-M_U = 238.0  # g/mol (LEU, ~U238 dominated)","-Y_gas = 0.31   # stable+long-lived Xe+Kr atoms per fission","-Y_CO  = 0.15   # CO molecules per fission (excess-oxygen, order-of-magnitude)","+# ---------- diffusion (reduced D'=D/r^2, s^-1) ----------","+def Dp_gas(Tc):       return 5.0e-3*np.exp(-155400/(R*K(Tc)))","+def Dp_Cs_kernel(Tc): return 0.90 *np.exp(-209000/(R*K(Tc)))","+def D_Cs_SiC(Tc):     return 1.011e-16*np.exp(-(125000/R)*(1/K(Tc)-1/K(1600)))  # anchored to annex ref"," ","-def fissions_per_particle(hm_g, npart, fima):","-    n_HM = (hm_g/npart)/M_U*NA           # HM atoms/particle","-    return fima*n_HM, n_HM","+# ---------- equivalent-sphere release from cumulative tau=integral(D' dt) ----------","+def F_release(tau):","+    if tau<=0: return 0.0","+    if tau<=0.15: return max(0.0,6*np.sqrt(tau/np.pi)-3*tau)","+    return 1-(6/np.pi**2)*np.exp(-np.pi**2*tau)"," ","-# ----------------------------------------------------------------------","-# Kernel diffusion (reduced D' = D/r^2, s^-1) Table 7.1","-# ----------------------------------------------------------------------","-def Dp_gas(Tc):   return 5.0e-3*np.exp(-155400/(R*K(Tc)))   # stable/long-lived gas","-def Dp_Cs_kernel(Tc): return 0.90*np.exp(-209000/(R*K(Tc)))","+# ---------- Weibull ----------","+SIC_MEAN=873.0; SIC_M=8.02; SIC_SCALE=SIC_MEAN/gamma(1+1/SIC_M)","+def Pf_sic(s):","+    return 0.0 if s<=0 else 1-np.exp(-(s/SIC_SCALE)**SIC_M)"," ","-# Cs in SiC (m^2/s) anchored to annex reference 1.011e-16 at 1600C, Q=125 kJ/mol","-def D_Cs_SiC(Tc):","-    return 1.011e-16*np.exp(-(125000/R)*(1/K(Tc) - 1/K(1600)))","+# ---------- residual SiC compression from irradiation, thermally annealed ----------","+def sigma_res(flu018,Tc):","+    base=min(60.0*(flu018/5.0)**2,300.0)","+    anneal=np.exp(-(Tc-1500)/250.0) if Tc>1500 else 1.0","+    return base*max(anneal,0.15)"," ","-# ----------------------------------------------------------------------","-# Equivalent-sphere fractional release (Eq 10.7/10.8) given Dp*t","-# ----------------------------------------------------------------------","-def F_release(Dpt):","-    if Dpt <= 0: return 0.0","-    if Dpt <= 0.15:","-        return max(0.0, 6*np.sqrt(Dpt/np.pi) - 3*Dpt)","-    else:","-        return 1 - (6/np.pi**2)*np.exp(-np.pi**2*Dpt)","+# ---------- schedules: list of (T_C, duration_h) for holds+ramps ----------","+# ramps represented at mean temperature of endpoints","+def sched(rows):  # rows: (T,dur)","+    return rows","+SCH={","+ \"A1\":[(300,0.5),(675,1.5),(1050,5.5),(1150,0.5),(1250,16.5),(1400,6.5),","+       (925,1),(950,9),(1600,500)],","+ \"A2\":[(300,0.5),(675,1.5),(1050,5.5),(1150,0.5),(1250,13.5),(1525,12),(1800,25.5),","+       (1050,1),(675,1.5),(1050,19.5),(1150,0.5),(1250,19),(1525,12),(1800,74.5)],","+ \"B\" :[(300,7),(675,2),(1050,13.5),(1325,11),(1600,99),(810,17),","+       (860,5.5),(1700,100),(860,17),(910,2),(1800,100),(910,17),(1050,7),(1050,1),(1800,300)],","+ \"C1\":[(300,0.5),(675,1.5),(1050,5.5),(1150,0.5),(1250,13.5),(1425,7.5),(1600,304)],","+ \"C2\":[(300,0.5),(675,1.5),(1050,5.5),(1150,0.5),(1250,13.5),(1425,7.5),(1600,304)],","+}"," ","-# ----------------------------------------------------------------------","-# Weibull SiC failure probability from peak tangential stress","-# ----------------------------------------------------------------------","-from math import gamma","-SIC_MEAN = 873.0; SIC_M = 8.02","-SIC_SCALE = SIC_MEAN/gamma(1+1/SIC_M)     # characteristic (scale) strength","-def Pf_sic(sigma):","-    if sigma <= 0: return 0.0","-    return 1 - np.exp(-(sigma/SIC_SCALE)**SIC_M)","-","-# ----------------------------------------------------------------------","-# Internal pressure & SiC membrane stress","-# free gas released from kernel over time t at temperature Tc, plus CO (assumed all freed)","-# ----------------------------------------------------------------------","-def sic_stress(G, n_HM, fima, Tc, t_h):","-    t = t_h*3600.0","-    N_f = fima*n_HM","-    F_g = F_release(Dp_gas(Tc)*t)            # fraction of gas released from kernel to void","-    n_gas = (Y_gas*N_f*F_g + Y_CO*N_f)/NA    # moles in void (CO taken fully released)","-    P = n_gas*R*K(Tc)/G['V_void']            # Pa","-    sig_p = P*G['r_m']/(2*G['t'])/1e6        # MPa membrane tension","-    return P/1e6, sig_p, F_g","-","-# residual irradiation-induced SiC compression (MPa), magnitude grows modestly with fluence,","-# partially annealed at accident T. Engineering estimate.","-def sigma_res(fluence_e018, Tc):","-    base = 60.0*fluence_e018/5.0*(fluence_e018/5.0)  # ~ grows with fluence^~2 (IPyC shrinkage)","-    base = min(base, 300.0)","-    # thermal anneal of residual stress at accident temperature (higher T -> more relaxed)","-    anneal = np.exp(-(Tc-1500)/250.0) if Tc>1500 else 1.0","-    return base*max(anneal, 0.15)","-","-# ----------------------------------------------------------------------","-# Cases","-# ----------------------------------------------------------------------","-cases = [","- dict(name=\"A1\", G=G_K3, npart=16400, hm=10.22, fima=0.077, flu01=3.9,","-      Tpeak=1600, tpeak=500, Tirr=1216, hold_desc=\"1600C/500h\"),","- dict(name=\"A2\", G=G_K3, npart=16400, hm=10.22, fima=0.106, flu01=6.0,","-      Tpeak=1800, tpeak=100, Tirr=983, hold_desc=\"1800C/100h (2 segments)\"),","- dict(name=\"B\",  G=G_K6, npart=14580, hm=9.4346, fima=0.109, flu01=4.8,","-      Tpeak=1800, tpeak=400, Tirr=1140, hold_desc=\"1600/1700/1800/1800C staged, 400h@>=1800\"),","- dict(name=\"C1\", G=G_P4, npart=1631, hm=1.018, fima=0.139, flu01=7.5,","-      Tpeak=1600, tpeak=304, Tirr=1075, hold_desc=\"1600C/304h\"),","- dict(name=\"C2\", G=G_P4, npart=1631, hm=1.018, fima=0.111, flu01=5.5,","-      Tpeak=1600, tpeak=304, Tirr=940, hold_desc=\"1600C/304h\"),","+cases=[","+ dict(name=\"A1\",G=G_K3,npart=16400,hm=10.22,   fima=0.077,flu01=3.9,thr=6.1e-5),","+ dict(name=\"A2\",G=G_K3,npart=16400,hm=10.22,   fima=0.106,flu01=6.0,thr=6.1e-5),","+ dict(name=\"B\", G=G_K6,npart=14580,hm=9.4346,  fima=0.109,flu01=4.8,thr=6.9e-5),","+ dict(name=\"C1\",G=G_P4,npart=1631, hm=1.018,   fima=0.139,flu01=7.5,thr=6.1e-4),","+ dict(name=\"C2\",G=G_P4,npart=1631, hm=1.018,   fima=0.111,flu01=5.5,thr=6.1e-4),"," ]"," ","-print(\"=\"*100)","-print(f\"{'SiC scale strength':30s}= {SIC_SCALE:.1f} MPa  (mean {SIC_MEAN}, m={SIC_M})\")","-print(\"=\"*100)","+print(f\"SiC scale strength = {SIC_SCALE:.0f} MPa (mean {SIC_MEAN}, m={SIC_M})\\n\"+\"=\"*90)","+summary=[]"," for c in cases:","-    G=c['G']; flu018=c['flu01']/1.10","-    N_f, n_HM = fissions_per_particle(c['hm'], c['npart'], c['fima'])","-    Tc=c['Tpeak']; th=c['tpeak']; t=th*3600","-    P, sig_p, F_g = sic_stress(G, n_HM, c['fima'], Tc, th)","-    sig_r = sigma_res(flu018, Tc)","-    sig_net = sig_p - sig_r","-    pf = Pf_sic(sig_net)","-    nfail = pf*c['npart']","-    # Cs release through intact SiC (equivalent sphere, D_SiC/r_m^2)","-    Dp_cs = D_Cs_SiC(Tc)/G['r_m']**2","-    F_cs_intact = F_release(Dp_cs*t)","-    # gas & Cs from failed particles: bare kernel","-    F_gas_failed = F_release(Dp_gas(Tc)*t)","-    F_cs_failed  = F_release(Dp_Cs_kernel(Tc)*t)","-    ff = nfail/c['npart']","-    # element releases","-    Kr_rel = ff*F_gas_failed","-    Cs_rel = ff*F_cs_failed + (1-ff)*F_cs_intact","-    print(f\"\\n--- Case {c['name']}  ({c['hold_desc']}) ---\")","-    print(f\" fissions/particle      = {N_f:.3e}\")","-    print(f\" gas atoms/particle     = {Y_gas*N_f:.3e}  CO/particle={Y_CO*N_f:.3e}\")","-    print(f\" void volume            = {G['V_void']:.3e} m^3 (poros {G['poros']:.2f})\")","-    print(f\" gas release from kernel F_g(t) = {F_g:.3f}\")","-    print(f\" internal pressure P    = {P:.1f} MPa\")","-    print(f\" SiC membrane tension   = {sig_p:.1f} MPa\")","-    print(f\" residual compression   = {sig_r:.1f} MPa  -> net = {sig_net:.1f} MPa\")","-    print(f\" Weibull Pf/particle    = {pf:.3e}  -> N_fail = {nfail:.2f} / {c['npart']}\")","-    print(f\" D_Cs_SiC({Tc}C)        = {D_Cs_SiC(Tc):.3e} m^2/s ; Dp*t(Cs,SiC)={Dp_cs*t:.3e}\")","-    print(f\" Cs release intact SiC  = {F_cs_intact:.3f}\")","-    print(f\" gas rel failed kernel  = {F_gas_failed:.3f} ; Cs rel failed kernel={F_cs_failed:.3f}\")","-    print(f\" ==> Kr-85 frac release = {Kr_rel:.3e}\")","-    print(f\" ==> Cs-137 frac release= {Cs_rel:.3e}\")","+    G=c['G']; flu018=c['flu01']/1.10; nhm=nHM(c['hm'],c['npart']); Nf=c['fima']*nhm","+    tau_cs=0.0; tau_gas=0.0; tau_csk=0.0","+    maxPf=0.0; onset=None; peakP=0; peakS=0","+    for (T,dur) in SCH[c['name']]:","+        dt=dur*3600","+        tau_gas+=Dp_gas(T)*dt","+        tau_cs +=D_Cs_SiC(T)/G['r_m']**2*dt","+        tau_csk+=Dp_Cs_kernel(T)*dt","+        # pressure using gas released so far, at this T","+        F_g=F_release(tau_gas)","+        n_void=(Y_gas*Nf*F_g+Y_CO*Nf)/NA","+        P=n_void*R*K(T)/G['V_void']; sig_p=P*G['r_m']/(2*G['t'])/1e6","+        sig_net=sig_p-sigma_res(flu018,T); pf=Pf_sic(sig_net)","+        if pf>maxPf: maxPf=pf; peakP=P/1e6; peakS=sig_net","+        if pf*c['npart']>=0.5 and onset is None: onset=(T,dur)","+    nfail=maxPf*c['npart']","+    F_cs_intact=F_release(tau_cs)","+    F_gas_failed=F_release(tau_gas)","+    F_cs_failed =F_release(tau_csk)","+    ff=nfail/c['npart']","+    Kr=ff*F_gas_failed","+    Cs=ff*F_cs_failed+(1-ff)*F_cs_intact","+    summary.append((c['name'],nfail,Kr,Cs,peakP,peakS,maxPf,F_cs_intact))","+    print(f\"\\n--- {c['name']} ---  fissions/part={Nf:.3e}  void={G['V_void']:.2e} m^3\")","+    print(f\"  peak SiC net tension  ~ {peakS:.0f} MPa  (P~{peakP:.0f} MPa)\")","+    print(f\"  Weibull Pf/particle   = {maxPf:.2e}  -> E[N_fail]={nfail:.3f}/{c['npart']}\")","+    print(f\"  onset (Pf*N>=0.5)     = {onset}\")","+    print(f\"  tau_Cs,SiC={tau_cs:.3e}  Cs release via intact SiC = {F_cs_intact:.3f}\")","+    print(f\"  tau_gas={tau_gas:.3f} (F={F_gas_failed:.3f})  tau_Cs,kernel={tau_csk:.2f} (F={F_cs_failed:.3f})\")","+    print(f\"  ==> Kr-85  frac release = {Kr:.2e}   ({Kr/c['thr']*1 if False else nfail:.3f} equiv failed part.)\")","+    print(f\"  ==> Cs-137 frac release = {Cs:.3f}\")","+","+print(\"\\n\"+\"=\"*90+\"\\nRANKING by Cs-137 release (severity):\")","+for n,nf,kr,cs,pp,ps,pf,fi in sorted(summary,key=lambda x:-x[3]):","+    print(f\"  {n}: Cs={cs:.3f}  Kr={kr:.2e}  E[Nfail]={nf:.3f}\")","+print(\"\\nRANKING by peak SiC failure probability:\")","+for n,nf,kr,cs,pp,ps,pf,fi in sorted(summary,key=lambda x:-x[6]):","+    print(f\"  {n}: Pf/part={pf:.2e} E[Nfail]={nf:.3f}  peakNetStress={ps:.0f} MPa\")"]}],"originalFile":"#!/usr/bin/env python3\n\"\"\"\nTRISO accident-heating failure & release predictions (offline).\nAll physics/correlations from inputs/03_material_properties.md (TECDOC-1674 annex).\nNo external data used.\n\"\"\"\nimport numpy as np\n\nR = 8.314  # J/mol/K\nNA = 6.02214e23\ndef K(Tc): return Tc + 273.15\n\n# ----------------------------------------------------------------------\n# Particle geometry per batch (um) -> m\n# ----------------------------------------------------------------------\ndef geom(kernel_d, buffer, ipyc, sic, opyc, rho_buffer):\n    a = kernel_d/2 * 1e-6                 # kernel radius m\n    r_i = (kernel_d/2 + buffer + ipyc)*1e-6   # SiC inner radius\n    r_o = r_i + sic*1e-6                  # SiC outer radius\n    r_m = 0.5*(r_i+r_o)                   # SiC mean radius\n    t   = sic*1e-6                        # SiC thickness\n    # buffer void volume\n    rb_o = (kernel_d/2 + buffer)*1e-6\n    V_buffer = 4/3*np.pi*(rb_o**3 - a**3)\n    poros = 1 - rho_buffer/2.10           # theoretical PyC density ~2.10 Mg/m3\n    V_void = poros*V_buffer               # dominant void; kernel open porosity neglected\n    return dict(a=a, r_i=r_i, r_o=r_o, r_m=r_m, t=t, V_void=V_void, poros=poros)\n\n# EUO2308 (K3, P4) and EUO2358 (K6)\nG_K3 = geom(497, 94, 41, 36, 40, 1.00)\nG_P4 = geom(497, 94, 41, 36, 40, 1.00)   # same batch 2308\nG_K6 = geom(508,102, 39, 36, 38, 1.02)\n\n# ----------------------------------------------------------------------\n# Fission / gas inventory\n# ----------------------------------------------------------------------\nM_U = 238.0  # g/mol (LEU, ~U238 dominated)\nY_gas = 0.31   # stable+long-lived Xe+Kr atoms per fission\nY_CO  = 0.15   # CO molecules per fission (excess-oxygen, order-of-magnitude)\n\ndef fissions_per_particle(hm_g, npart, fima):\n    n_HM = (hm_g/npart)/M_U*NA           # HM atoms/particle\n    return fima*n_HM, n_HM\n\n# ----------------------------------------------------------------------\n# Kernel diffusion (reduced D' = D/r^2, s^-1) Table 7.1\n# ----------------------------------------------------------------------\ndef Dp_gas(Tc):   return 5.0e-3*np.exp(-155400/(R*K(Tc)))   # stable/long-lived gas\ndef Dp_Cs_kernel(Tc): return 0.90*np.exp(-209000/(R*K(Tc)))\n\n# Cs in SiC (m^2/s) anchored to annex reference 1.011e-16 at 1600C, Q=125 kJ/mol\ndef D_Cs_SiC(Tc):\n    return 1.011e-16*np.exp(-(125000/R)*(1/K(Tc) - 1/K(1600)))\n\n# ----------------------------------------------------------------------\n# Equivalent-sphere fractional release (Eq 10.7/10.8) given Dp*t\n# ----------------------------------------------------------------------\ndef F_release(Dpt):\n    if Dpt <= 0: return 0.0\n    if Dpt <= 0.15:\n        return max(0.0, 6*np.sqrt(Dpt/np.pi) - 3*Dpt)\n    else:\n        return 1 - (6/np.pi**2)*np.exp(-np.pi**2*Dpt)\n\n# ----------------------------------------------------------------------\n# Weibull SiC failure probability from peak tangential stress\n# ----------------------------------------------------------------------\nfrom math import gamma\nSIC_MEAN = 873.0; SIC_M = 8.02\nSIC_SCALE = SIC_MEAN/gamma(1+1/SIC_M)     # characteristic (scale) strength\ndef Pf_sic(sigma):\n    if sigma <= 0: return 0.0\n    return 1 - np.exp(-(sigma/SIC_SCALE)**SIC_M)\n\n# ----------------------------------------------------------------------\n# Internal pressure & SiC membrane stress\n# free gas released from kernel over time t at temperature Tc, plus CO (assumed all freed)\n# ----------------------------------------------------------------------\ndef sic_stress(G, n_HM, fima, Tc, t_h):\n    t = t_h*3600.0\n    N_f = fima*n_HM\n    F_g = F_release(Dp_gas(Tc)*t)            # fraction of gas released from kernel to void\n    n_gas = (Y_gas*N_f*F_g + Y_CO*N_f)/NA    # moles in void (CO taken fully released)\n    P = n_gas*R*K(Tc)/G['V_void']            # Pa\n    sig_p = P*G['r_m']/(2*G['t'])/1e6        # MPa membrane tension\n    return P/1e6, sig_p, F_g\n\n# residual irradiation-induced SiC compression (MPa), magnitude grows modestly with fluence,\n# partially annealed at accident T. Engineering estimate.\ndef sigma_res(fluence_e018, Tc):\n    base = 60.0*fluence_e018/5.0*(fluence_e018/5.0)  # ~ grows with fluence^~2 (IPyC shrinkage)\n    base = min(base, 300.0)\n    # thermal anneal of residual stress at accident temperature (higher T -> more relaxed)\n    anneal = np.exp(-(Tc-1500)/250.0) if Tc>1500 else 1.0\n    return base*max(anneal, 0.15)\n\n# ----------------------------------------------------------------------\n# Cases\n# ----------------------------------------------------------------------\ncases = [\n dict(name=\"A1\", G=G_K3, npart=16400, hm=10.22, fima=0.077, flu01=3.9,\n      Tpeak=1600, tpeak=500, Tirr=1216, hold_desc=\"1600C/500h\"),\n dict(name=\"A2\", G=G_K3, npart=16400, hm=10.22, fima=0.106, flu01=6.0,\n      Tpeak=1800, tpeak=100, Tirr=983, hold_desc=\"1800C/100h (2 segments)\"),\n dict(name=\"B\",  G=G_K6, npart=14580, hm=9.4346, fima=0.109, flu01=4.8,\n      Tpeak=1800, tpeak=400, Tirr=1140, hold_desc=\"1600/1700/1800/1800C staged, 400h@>=1800\"),\n dict(name=\"C1\", G=G_P4, npart=1631, hm=1.018, fima=0.139, flu01=7.5,\n      Tpeak=1600, tpeak=304, Tirr=1075, hold_desc=\"1600C/304h\"),\n dict(name=\"C2\", G=G_P4, npart=1631, hm=1.018, fima=0.111, flu01=5.5,\n      Tpeak=1600, tpeak=304, Tirr=940, hold_desc=\"1600C/304h\"),\n]\n\nprint(\"=\"*100)\nprint(f\"{'SiC scale strength':30s}= {SIC_SCALE:.1f} MPa  (mean {SIC_MEAN}, m={SIC_M})\")\nprint(\"=\"*100)\nfor c in cases:\n    G=c['G']; flu018=c['flu01']/1.10\n    N_f, n_HM = fissions_per_particle(c['hm'], c['npart'], c['fima'])\n    Tc=c['Tpeak']; th=c['tpeak']; t=th*3600\n    P, sig_p, F_g = sic_stress(G, n_HM, c['fima'], Tc, th)\n    sig_r = sigma_res(flu018, Tc)\n    sig_net = sig_p - sig_r\n    pf = Pf_sic(sig_net)\n    nfail = pf*c['npart']\n    # Cs release through intact SiC (equivalent sphere, D_SiC/r_m^2)\n    Dp_cs = D_Cs_SiC(Tc)/G['r_m']**2\n    F_cs_intact = F_release(Dp_cs*t)\n    # gas & Cs from failed particles: bare kernel\n    F_gas_failed = F_release(Dp_gas(Tc)*t)\n    F_cs_failed  = F_release(Dp_Cs_kernel(Tc)*t)\n    ff = nfail/c['npart']\n    # element releases\n    Kr_rel = ff*F_gas_failed\n    Cs_rel = ff*F_cs_failed + (1-ff)*F_cs_intact\n    print(f\"\\n--- Case {c['name']}  ({c['hold_desc']}) ---\")\n    print(f\" fissions/particle      = {N_f:.3e}\")\n    print(f\" gas atoms/particle     = {Y_gas*N_f:.3e}  CO/particle={Y_CO*N_f:.3e}\")\n    print(f\" void volume            = {G['V_void']:.3e} m^3 (poros {G['poros']:.2f})\")\n    print(f\" gas release from kernel F_g(t) = {F_g:.3f}\")\n    print(f\" internal pressure P    = {P:.1f} MPa\")\n    print(f\" SiC membrane tension   = {sig_p:.1f} MPa\")\n    print(f\" residual compression   = {sig_r:.1f} MPa  -> net = {sig_net:.1f} MPa\")\n    print(f\" Weibull Pf/particle    = {pf:.3e}  -> N_fail = {nfail:.2f} / {c['npart']}\")\n    print(f\" D_Cs_SiC({Tc}C)        = {D_Cs_SiC(Tc):.3e} m^2/s ; Dp*t(Cs,SiC)={Dp_cs*t:.3e}\")\n    print(f\" Cs release intact SiC  = {F_cs_intact:.3f}\")\n    print(f\" gas rel failed kernel  = {F_gas_failed:.3f} ; Cs rel failed kernel={F_cs_failed:.3f}\")\n    print(f\" ==> Kr-85 frac release = {Kr_rel:.3e}\")\n    print(f\" ==> Cs-137 frac release= {Cs_rel:.3e}\")\n","userModified":false}}
