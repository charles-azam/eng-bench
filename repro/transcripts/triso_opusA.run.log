----------------------\n# Fission / gas inventory\n# ----------------------------------------------------------------------\nM_U = 238.0  # g/mol (LEU, ~U238 dominated)\nY_gas = 0.31   # stable+long-lived Xe+Kr atoms per fission\nY_CO  = 0.15   # CO molecules per fission (excess-oxygen, order-of-magnitude)\n\ndef fissions_per_particle(hm_g, npart, fima):\n    n_HM = (hm_g/npart)/M_U*NA           # HM atoms/particle\n    return fima*n_HM, n_HM\n\n# ----------------------------------------------------------------------\n# Kernel diffusion (reduced D' = D/r^2, s^-1) Table 7.1\n# ----------------------------------------------------------------------\ndef Dp_gas(Tc):   return 5.0e-3*np.exp(-155400/(R*K(Tc)))   # stable/long-lived gas\ndef Dp_Cs_kernel(Tc): return 0.90*np.exp(-209000/(R*K(Tc)))\n\n# Cs in SiC (m^2/s) anchored to annex reference 1.011e-16 at 1600C, Q=125 kJ/mol\ndef D_Cs_SiC(Tc):\n    return 1.011e-16*np.exp(-(125000/R)*(1/K(Tc) - 1/K(1600)))\n\n# ----------------------------------------------------------------------\n# Equivalent-sphere fractional release (Eq 10.7/10.8) given Dp*t\n# ----------------------------------------------------------------------\ndef F_release(Dpt):\n    if Dpt <= 0: return 0.0\n    if Dpt <= 0.15:\n        return max(0.0, 6*np.sqrt(Dpt/np.pi) - 3*Dpt)\n    else:\n        return 1 - (6/np.pi**2)*np.exp(-np.pi**2*Dpt)\n\n# ----------------------------------------------------------------------\n# Weibull SiC failure probability from peak tangential stress\n# ----------------------------------------------------------------------\nfrom math import gamma\nSIC_MEAN = 873.0; SIC_M = 8.02\nSIC_SCALE = SIC_MEAN/gamma(1+1/SIC_M)     # characteristic (scale) strength\ndef Pf_sic(sigma):\n    if sigma <= 0: return 0.0\n    return 1 - np.exp(-(sigma/SIC_SCALE)**SIC_M)\n\n# ----------------------------------------------------------------------\n# Internal pressure & SiC membrane stress\n# free gas released from kernel over time t at temperature Tc, plus CO (assumed all freed)\n# ----------------------------------------------------------------------\ndef sic_stress(G, n_HM, fima, Tc, t_h):\n    t = t_h*3600.0\n    N_f = fima*n_HM\n    F_g = F_release(Dp_gas(Tc)*t)            # fraction of gas released from kernel to void\n    n_gas = (Y_gas*N_f*F_g + Y_CO*N_f)/NA    # moles in void (CO taken fully released)\n    P = n_gas*R*K(Tc)/G['V_void']            # Pa\n    sig_p = P*G['r_m']/(2*G['t'])/1e6        # MPa membrane tension\n    return P/1e6, sig_p, F_g\n\n# residual irradiation-induced SiC compression (MPa), magnitude grows modestly with fluence,\n# partially annealed at accident T. Engineering estimate.\ndef sigma_res(fluence_e018, Tc):\n    base = 60.0*fluence_e018/5.0*(fluence_e018/5.0)  # ~ grows with fluence^~2 (IPyC shrinkage)\n    base = min(base, 300.0)\n    # thermal anneal of residual stress at accident temperature (higher T -> more relaxed)\n    anneal = np.exp(-(Tc-1500)/250.0) if Tc>1500 else 1.0\n    return base*max(anneal, 0.15)\n\n# ----------------------------------------------------------------------\n# Cases\n# ----------------------------------------------------------------------\ncases = [\n dict(name=\"A1\", G=G_K3, npart=16400, hm=10.22, fima=0.077, flu01=3.9,\n      Tpeak=1600, tpeak=500, Tirr=1216, hold_desc=\"1600C/500h\"),\n dict(name=\"A2\", G=G_K3, npart=16400, hm=10.22, fima=0.106, flu01=6.0,\n      Tpeak=1800, tpeak=100, Tirr=983, hold_desc=\"1800C/100h (2 segments)\"),\n dict(name=\"B\",  G=G_K6, npart=14580, hm=9.4346, fima=0.109, flu01=4.8,\n      Tpeak=1800, tpeak=400, Tirr=1140, hold_desc=\"1600/1700/1800/1800C staged, 400h@>=1800\"),\n dict(name=\"C1\", G=G_P4, npart=1631, hm=1.018, fima=0.139, flu01=7.5,\n      Tpeak=1600, tpeak=304, Tirr=1075, hold_desc=\"1600C/304h\"),\n dict(name=\"C2\", G=G_P4, npart=1631, hm=1.018, fima=0.111, flu01=5.5,\n      Tpeak=1600, tpeak=304, Tirr=940, hold_desc=\"1600C/304h\"),\n]\n\nprint(\"=\"*100)\nprint(f\"{'SiC scale strength':30s}= {SIC_SCALE:.1f} MPa  (mean {SIC_MEAN}, m={SIC_M})\")\nprint(\"=\"*100)\nfor c in cases:\n    G=c['G']; flu018=c['flu01']/1.10\n    N_f, n_HM = fissions_per_particle(c['hm'], c['npart'], c['fima'])\n    Tc=c['Tpeak']; th=c['tpeak']; t=th*3600\n    P, sig_p, F_g = sic_stress(G, n_HM, c['fima'], Tc, th)\n    sig_r = sigma_res(flu018, Tc)\n    sig_net = sig_p - sig_r\n    pf = Pf_sic(sig_net)\n    nfail = pf*c['npart']\n    # Cs release through intact SiC (equivalent sphere, D_SiC/r_m^2)\n    Dp_cs = D_Cs_SiC(Tc)/G['r_m']**2\n    F_cs_intact = F_release(Dp_cs*t)\n    # gas & Cs from failed particles: bare kernel\n    F_gas_failed = F_release(Dp_gas(Tc)*t)\n    F_cs_failed  = F_release(Dp_Cs_kernel(Tc)*t)\n    ff = nfail/c['npart']\n    # element releases\n    Kr_rel = ff*F_gas_failed\n    Cs_rel = ff*F_cs_failed + (1-ff)*F_cs_intact\n    print(f\"\\n--- Case {c['name']}  ({c['hold_desc']}) ---\")\n    print(f\" fissions/particle      = {N_f:.3e}\")\n    print(f\" gas atoms/particle     = {Y_gas*N_f:.3e}  CO/particle={Y_CO*N_f:.3e}\")\n    print(f\" void volume            = {G['V_void']:.3e} m^3 (poros {G['poros']:.2f})\")\n    print(f\" gas release from kernel F_g(t) = {F_g:.3f}\")\n    print(f\" internal pressure P    = {P:.1f} MPa\")\n    print(f\" SiC membrane tension   = {sig_p:.1f} MPa\")\n    print(f\" residual compression   = {sig_r:.1f} MPa  -> net = {sig_net:.1f} MPa\")\n    print(f\" Weibull Pf/particle    = {pf:.3e}  -> N_fail = {nfail:.2f} / {c['npart']}\")\n    print(f\" D_Cs_SiC({Tc}C)        = {D_Cs_SiC(Tc):.3e} m^2/s ; Dp*t(Cs,SiC)={Dp_cs*t:.3e}\")\n    print(f\" Cs release intact SiC  = {F_cs_intact:.3f}\")\n    print(f\" gas rel failed kernel  = {F_gas_failed:.3f} ; Cs rel failed kernel={F_cs_failed:.3f}\")\n    print(f\" ==> Kr-85 frac release = {Kr_rel:.3e}\")\n    print(f\" ==> Cs-137 frac release= {Cs_rel:.3e}\")\n","structuredPatch":[],"originalFile":null,"userModified":false}}
