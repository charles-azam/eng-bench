{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013jUEYBezFWQBF4KLAUoH5L","type":"tool_result","content":"1\t\"\"\"\n2\tFinal analysis: load OpenMC k_inf(T), compute isothermal temperature coefficient\n3\talpha(T) with uncertainty, run nominal LOFC transient + sensitivity study, and\n4\temit results (JSON) and a plot. Consumes runs/main/keff.csv (BP on).\n5\t\"\"\"\n6\timport json, numpy as np\n7\timport matplotlib\n8\tmatplotlib.use('Agg')\n9\timport matplotlib.pyplot as plt\n10\tfrom scipy.interpolate import interp1d\n11\timport transient as TR\n12\t\n13\tRNG = np.random.default_rng(12345)\n14\t\n15\tdef alpha_curve(Tk, kk, sk, Tq):\n16\t    \"\"\"alpha(T)=dk/dT/k^2 [pcm/K] with 1-sigma via Monte Carlo over k points.\"\"\"\n17\t    N = 4000\n18\t    a_samp = np.zeros((N, len(Tq)))\n19\t    dk_samp = np.zeros(N)  # slope 294->1200 overall\n20\t    for i in range(N):\n21\t        kp = kk + RNG.normal(0, 1, len(kk))*sk\n22\t        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n23\t        for j, T in enumerate(Tq):\n24\t            # isothermal reactivity coefficient of the critical core = (1/k) dk/dT\n25\t            # (logarithmic derivative; rod/leakage multiplier cancels)\n26\t            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T))*1e5\n27\t    return a_samp.mean(0), a_samp.std(0)\n28\t\n29\tdef main():\n30\t    Tk, kk, sk = TR.load_kT('runs/main/keff.csv', bp=1)\n31\t    print(\"k_inf(T)  [BP ON, main]:\")\n32\t    for T,k,s in zip(Tk,kk,sk): print(f\"  {T:6.1f} K : {k:.5f} +/- {s:.5f}\")\n33\t    Tq = np.array([400,600,800,1000,1200.])\n34\t    am, asd = alpha_curve(Tk, kk, sk, Tq)\n35\t    print(\"isothermal temperature coefficient alpha(T)  [BP ON]:\")\n36\t    for T,a,s in zip(Tq,am,asd): print(f\"  alpha({T:.0f}K) = {a:7.2f} +/- {s:4.2f} pcm/K\")\n37\t\n38\t    # ---- second BP variant (burnable poison OFF) — brackets the coefficient ----\n39\t    Tk2, kk2, sk2 = TR.load_kT('runs/nobp/keff.csv', bp=0)\n40\t    print(\"\\nk_inf(T)  [BP OFF, nobp]:\")\n41\t    for T,k,s in zip(Tk2,kk2,sk2): print(f\"  {T:6.1f} K : {k:.5f} +/- {s:.5f}\")\n42\t    Tq2 = np.array([400,600,800,1000,1100.])  # nobp sweep spans 294..1200\n43\t    am2, asd2 = alpha_curve(Tk2, kk2, sk2, Tq2)\n44\t    print(\"isothermal temperature coefficient alpha(T)  [BP OFF]:\")\n45\t    for T,a,s in zip(Tq2,am2,asd2): print(f\"  alpha({T:.0f}K) = {a:7.2f} +/- {s:4.2f} pcm/K\")\n46\t    # average coefficient over the operating range for each variant (pcm/K)\n47\t    a_on  = float(am.mean());  a_off = float(am2.mean())\n48\t    print(f\"\\nrange-avg alpha: BP-on {a_on:.2f} pcm/K, BP-off {a_off:.2f} pcm/K \"\n49\t          f\"(bracket [{min(a_on,a_off):.2f}, {max(a_on,a_off):.2f}])\")\n50\t\n51\t    # try beta_eff from prompt-only run if present\n52\t    beta_eff = 0.0065; beta_sig = 0.0\n53\t    try:\n54\t        import csv\n55\t        with open('runs/kin/keff.csv') as f:\n56\t            rows=list(csv.DictReader(f))\n57\t        kk_full = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n58\t                   for r in rows if int(r['prompt_only'])==0}\n59\t        kk_pr   = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n60\t                   for r in rows if int(r['prompt_only'])==1}\n61\t        T0=list(kk_pr.keys())[0]\n62\t        kf,sf=kk_full.get(T0,(None,None)); kp,sp=kk_pr[T0]\n63\t        if kf:\n64\t            beta_eff=1-kp/kf\n65\t            beta_sig=(kp/kf)*np.hypot(sf/kf,sp/kp)\n66\t            print(f\"beta_eff (prompt method @ {T0}K) = {beta_eff:.5f} +/- {beta_sig:.5f}\")\n67\t    except FileNotFoundError:\n68\t        print(\"beta_eff: prompt-only run not found; using 0.0065 (design-basis).\")\n69\t\n70\t    Top = 823.0   # core-avg graphite temp at 9 MW (30%), nominal ~550 C\n71\t    drho, kfun = TR.make_drho(Tk, kk, Top)\n72\t\n73\t    # Nominal thermal parameters. Gcr/Grv are geometry-informed: radial graphite\n74\t    # conduction (k~40 W/m/K, core r~1.15 m, H=2.9 m) gives core->reflector\n75\t    # conductance of order 1-3 kW/K; reflector->vessel similar (conduction+gap\n76\t    # radiation). L0 is the passive (non-coolant) heat leak at the 30%-power test\n77\t    # condition, ~0.3 MW (< the 0.6 MW full-power VCS rating). See sources.md.\n78\t    base = dict(Top=Top, P0=9e6, Mc=14000.0, Mr=45000.0, Mv=100000.0,\n79\t                Gcr=2000.0, Grv=2500.0, Q0=0.3e6, L0=0.3e6,\n80\t                Ts=320.0, pexp=1.5, t_op=30*24*3600.0, Lam=1e-3,\n81\t                t_end=6.0*24*3600, S=1e-6)\n82\t    sol, beff = TR.run(base, drho, beta_eff)\n83\t    s0 = TR.summarize(sol, base['P0'], Top, drho)\n84\t    print(\"\\n=== NOMINAL transient ===\")\n85\t    print(f\"  power min (first 30 min): {s0['Pmin_early']/1e3:.2f} kW at {s0['tmin']/60:.1f} min\")\n86\t    print(f\"  peak core temp: {s0['Tc_peak']-273:.0f} C at {s0['tpeak']/3600:.2f} h\")\n87\t    print(f\"  recriticality time: {s0['trec']/3600:.1f} h\" if s0['trec'] else \"  no recriticality\")\n88\t    print(f\"  stabilized fission power: {s0['P_stab']/1e3:.0f} kW ({s0['P_stab']/base['P0']*100:.1f}% of pre-trip 9MW)\")\n89\t    print(f\"  peak vessel temp: {s0['Tv_peak']-273:.0f} C (end {s0['Tv_end']-273:.0f} C)\")\n90\t\n91\t    # ---------- Sensitivity study (randomized over uncertain thermal params) ----------\n92\t    print(\"\\n=== SENSITIVITY (random sample over thermal parameters) ===\")\n93\t    NS = 400\n94\t    rows = []\n95\t    for _ in range(NS):\n96\t        Mc  = RNG.uniform(10000, 20000)\n97\t        Mr  = RNG.uniform(25000, 90000)     # responsive reflector graphite\n98\t        Gcr = RNG.uniform(3000, 12000)      # core<->reflector conductance\n99\t        Grv = RNG.uniform(2000, 8000)       # reflector<->vessel conductance\n100\t        L0  = RNG.uniform(0.3e6, 0.9e6)     # passive leak / VCS capacity\n101\t        pexp= RNG.uniform(1.0, 2.5)\n102\t        Topv= RNG.uniform(753., 893.)       # core-avg graphite temp at 9 MW\n103\t        top = RNG.uniform(3, 60)*24*3600.   # prior operating time\n104\t        p = dict(base); p.update(Mc=Mc,Mr=Mr,Gcr=Gcr,Grv=Grv,Q0=L0,L0=L0,\n105\t                                 pexp=pexp,Top=Topv,t_op=top)\n106\t        dr,_ = TR.make_drho(Tk, kk, Topv)\n107\t        try:\n108\t            so,_ = TR.run(p, dr, beta_eff)\n109\t            ss = TR.summarize(so, p['P0'], Topv, dr)\n110\t            rows.append((ss['trec']/3600 if ss['trec'] else np.nan,\n111\t                         ss['P_stab']/1e3, ss['Tc_peak']-273, ss['Tv_peak']-273))\n112\t        except Exception:\n113\t            continue\n114\t    G = np.array(rows)\n115\t    trec = G[:,0][~np.isnan(G[:,0])]; pstab=G[:,1]; tcpk=G[:,2]; tvpk=G[:,3]\n116\t    pc = lambda a,q: float(np.percentile(a,q))\n117\t    print(f\"  recriticality time: median {np.median(trec):.1f} h, \"\n118\t          f\"P10-P90 [{pc(trec,10):.1f}, {pc(trec,90):.1f}] h (min {trec.min():.1f}, max {trec.max():.1f})\")\n119\t    print(f\"  stabilized fission power: median {np.median(pstab):.0f} kW, \"\n120\t          f\"[{pc(pstab,10):.0f}, {pc(pstab,90):.0f}] kW\")\n121\t    print(f\"  peak core graphite temp: median {np.median(tcpk):.0f} C, \"\n122\t          f\"[{pc(tcpk,10):.0f}, {pc(tcpk,90):.0f}] C, max {tcpk.max():.0f} C\")\n123\t    print(f\"  peak vessel temp: median {np.median(tvpk):.0f} C, max {tvpk.max():.0f} C\")\n124\t\n125\t    # ---------- Plot ----------\n126\t    fig, ax = plt.subplots(2,1, figsize=(8,7), sharex=True)\n127\t    t = sol.t/3600\n128\t    ax[0].plot(t, sol.y[0]/1e6, 'b'); ax[0].set_yscale('log')\n129\t    ax[0].set_ylabel('Fission power (MW)'); ax[0].grid(True, which='both', alpha=.3)\n130\t    ax[0].axhline(9,ls='--',c='gray',lw=.8); ax[0].set_ylim(1e-4,20)\n131\t    if s0['trec']: ax[0].axvline(s0['trec']/3600, ls=':', c='r', label=f\"recrit {s0['trec']/3600:.1f} h\")\n132\t    ax[0].legend(); ax[0].set_title('HTTR LOFC (9 MWt, all circulators trip, no scram, VCS on) — computed')\n133\t    ax[1].plot(t, sol.y[7]-273, 'r', label='core graphite (feedback)')\n134\t    ax[1].plot(t, sol.y[8]-273, 'orange', label='reflector')\n135\t    ax[1].plot(t, sol.y[9]-273, 'green', label='vessel (RPV)')\n136\t    ax[1].axhline(Top-273, ls='--', c='k', lw=.8, label=f'T_op {Top-273:.0f} C')\n137\t    ax[1].set_ylabel('Temperature (C)'); ax[1].set_xlabel('Time (h)')\n138\t    ax[1].grid(True, alpha=.3); ax[1].legend(); ax[1].set_xlim(0, 120)\n139\t    fig.tight_layout(); fig.savefig('output/lofc_transient.png', dpi=110)\n140\t    print(\"\\nsaved output/lofc_transient.png\")\n141\t\n142\t    out = dict(k_T={float(T):[float(k),float(s)] for T,k,s in zip(Tk,kk,sk)},\n143\t               alpha_T={float(T):[float(a),float(s)] for T,a,s in zip(Tq,am,asd)},\n144\t               k_T_nobp={float(T):[float(k),float(s)] for T,k,s in zip(Tk2,kk2,sk2)},\n145\t               alpha_T_nobp={float(T):[float(a),float(s)] for T,a,s in zip(Tq2,am2,asd2)},\n146\t               alpha_bracket_pcmK=[min(a_on,a_off),max(a_on,a_off)],\n147\t               alpha_avg_on_pcmK=a_on, alpha_avg_off_pcmK=a_off,\n148\t               beta_eff=float(beta_eff), beta_eff_sigma=float(beta_sig),\n149\t               nominal=dict(Pmin_kW=float(s0['Pmin_early']/1e3),\n150\t                            tmin_min=float(s0['tmin']/60),\n151\t                            Tc_peak_C=float(s0['Tc_peak']-273),\n152\t                            tpeak_h=float(s0['tpeak']/3600),\n153\t                            trec_h=float(s0['trec']/3600) if s0['trec'] else None,\n154\t                            Pstab_kW=float(s0['P_stab']/1e3),\n155\t                            Tv_peak_C=float(s0['Tv_peak']-273),\n156\t                            Tv_end_C=float(s0['Tv_end']-273)),\n157\t               sens=dict(trec_h=[pc(trec,10),float(np.median(trec)),pc(trec,90),float(trec.min()),float(trec.max())],\n158\t                         Pstab_kW=[pc(pstab,10),float(np.median(pstab)),pc(pstab,90)],\n159\t                         Tcpeak_C=[pc(tcpk,10),float(np.median(tcpk)),pc(tcpk,90),float(tcpk.max())],\n160\t                         Tvpeak_C=[float(np.median(tvpk)),float(tvpk.max())]))\n161\t    json.dump(out, open('output/results.json','w'), indent=2)\n162\t    print(\"saved output/results.json\")\n163\t\n164\tif __name__ == '__main__':\n165\t    main()\n166\t"}]},"parent_tool_use_id":null,"session_id":"d6d8b148-c850-46f2-9bbc-b7461be96ce5","uuid":"cae2a4c5-e4c9-4198-86f6-58d0aebc466b","timestamp":"2026-07-03T17:25:12.481Z","tool_use_result":{"type":"text","file":{"filePath":"/root/bench/httr_xenon/analyze.py","content":"\"\"\"\nFinal analysis: load OpenMC k_inf(T), compute isothermal temperature coefficient\nalpha(T) with uncertainty, run nominal LOFC transient + sensitivity study, and\nemit results (JSON) and a plot. Consumes runs/main/keff.csv (BP on).\n\"\"\"\nimport json, numpy as np\nimport matplotlib\nmatplotlib.use('Agg')\nimport matplotlib.pyplot as plt\nfrom scipy.interpolate import interp1d\nimport transient as TR\n\nRNG = np.random.default_rng(12345)\n\ndef alpha_curve(Tk, kk, sk, Tq):\n    \"\"\"alpha(T)=dk/dT/k^2 [pcm/K] with 1-sigma via Monte Carlo over k points.\"\"\"\n    N = 4000\n    a_samp = np.zeros((N, len(Tq)))\n    dk_samp = np.zeros(N)  # slope 294->1200 overall\n    for i in range(N):\n        kp = kk + RNG.normal(0, 1, len(kk))*sk\n        f = interp1d(Tk, kp, kind='quadratic', fill_value='extrapolate')\n        for j, T in enumerate(Tq):\n            # isothermal reactivity coefficient of the critical core = (1/k) dk/dT\n            # (logarithmic derivative; rod/leakage multiplier cancels)\n            a_samp[i, j] = (f(T+15)-f(T-15))/(30.0*f(T))*1e5\n    return a_samp.mean(0), a_samp.std(0)\n\ndef main():\n    Tk, kk, sk = TR.load_kT('runs/main/keff.csv', bp=1)\n    print(\"k_inf(T)  [BP ON, main]:\")\n    for T,k,s in zip(Tk,kk,sk): print(f\"  {T:6.1f} K : {k:.5f} +/- {s:.5f}\")\n    Tq = np.array([400,600,800,1000,1200.])\n    am, asd = alpha_curve(Tk, kk, sk, Tq)\n    print(\"isothermal temperature coefficient alpha(T)  [BP ON]:\")\n    for T,a,s in zip(Tq,am,asd): print(f\"  alpha({T:.0f}K) = {a:7.2f} +/- {s:4.2f} pcm/K\")\n\n    # ---- second BP variant (burnable poison OFF) — brackets the coefficient ----\n    Tk2, kk2, sk2 = TR.load_kT('runs/nobp/keff.csv', bp=0)\n    print(\"\\nk_inf(T)  [BP OFF, nobp]:\")\n    for T,k,s in zip(Tk2,kk2,sk2): print(f\"  {T:6.1f} K : {k:.5f} +/- {s:.5f}\")\n    Tq2 = np.array([400,600,800,1000,1100.])  # nobp sweep spans 294..1200\n    am2, asd2 = alpha_curve(Tk2, kk2, sk2, Tq2)\n    print(\"isothermal temperature coefficient alpha(T)  [BP OFF]:\")\n    for T,a,s in zip(Tq2,am2,asd2): print(f\"  alpha({T:.0f}K) = {a:7.2f} +/- {s:4.2f} pcm/K\")\n    # average coefficient over the operating range for each variant (pcm/K)\n    a_on  = float(am.mean());  a_off = float(am2.mean())\n    print(f\"\\nrange-avg alpha: BP-on {a_on:.2f} pcm/K, BP-off {a_off:.2f} pcm/K \"\n          f\"(bracket [{min(a_on,a_off):.2f}, {max(a_on,a_off):.2f}])\")\n\n    # try beta_eff from prompt-only run if present\n    beta_eff = 0.0065; beta_sig = 0.0\n    try:\n        import csv\n        with open('runs/kin/keff.csv') as f:\n            rows=list(csv.DictReader(f))\n        kk_full = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n                   for r in rows if int(r['prompt_only'])==0}\n        kk_pr   = {float(r['T_K']):(float(r['keff']),float(r['keff_sigma']))\n                   for r in rows if int(r['prompt_only'])==1}\n        T0=list(kk_pr.keys())[0]\n        kf,sf=kk_full.get(T0,(None,None)); kp,sp=kk_pr[T0]\n        if kf:\n            beta_eff=1-kp/kf\n            beta_sig=(kp/kf)*np.hypot(sf/kf,sp/kp)\n            print(f\"beta_eff (prompt method @ {T0}K) = {beta_eff:.5f} +/- {beta_sig:.5f}\")\n    except FileNotFoundError:\n        print(\"beta_eff: prompt-only run not found; using 0.0065 (design-basis).\")\n\n    Top = 823.0   # core-avg graphite temp at 9 MW (30%), nominal ~550 C\n    drho, kfun = TR.make_drho(Tk, kk, Top)\n\n    # Nominal thermal parameters. Gcr/Grv are geometry-informed: radial graphite\n    # conduction (k~40 W/m/K, core r~1.15 m, H=2.9 m) gives core->reflector\n    # conductance of order 1-3 kW/K; reflector->vessel similar (conduction+gap\n    # radiation). L0 is the passive (non-coolant) heat leak at the 30%-power test\n    # condition, ~0.3 MW (< the 0.6 MW full-power VCS rating). See sources.md.\n    base = dict(Top=Top, P0=9e6, Mc=14000.0, Mr=45000.0, Mv=100000.0,\n                Gcr=2000.0, Grv=2500.0, Q0=0.3e6, L0=0.3e6,\n                Ts=320.0, pexp=1.5, t_op=30*24*3600.0, Lam=1e-3,\n                t_end=6.0*24*3600, S=1e-6)\n    sol, beff = TR.run(base, drho, beta_eff)\n    s0 = TR.summarize(sol, base['P0'], Top, drho)\n    print(\"\\n=== NOMINAL transient ===\")\n    print(f\"  power min (first 30 min): {s0['Pmin_early']/1e3:.2f} kW at {s0['tmin']/60:.1f} min\")\n    print(f\"  peak core temp: {s0['Tc_peak']-273:.0f} C at {s0['tpeak']/3600:.2f} h\")\n    print(f\"  recriticality time: {s0['trec']/3600:.1f} h\" if s0['trec'] else \"  no recriticality\")\n    print(f\"  stabilized fission power: {s0['P_stab']/1e3:.0f} kW ({s0['P_stab']/base['P0']*100:.1f}% of pre-trip 9MW)\")\n    print(f\"  peak vessel temp: {s0['Tv_peak']-273:.0f} C (end {s0['Tv_end']-273:.0f} C)\")\n\n    # ---------- Sensitivity study (randomized over uncertain thermal params) ----------\n    print(\"\\n=== SENSITIVITY (random sample over thermal parameters) ===\")\n    NS = 400\n    rows = []\n    for _ in range(NS):\n        Mc  = RNG.uniform(10000, 20000)\n        Mr  = RNG.uniform(25000, 90000)     # responsive reflector graphite\n        Gcr = RNG.uniform(3000, 12000)      # core<->reflector conductance\n        Grv = RNG.uniform(2000, 8000)       # reflector<->vessel conductance\n        L0  = RNG.uniform(0.3e6, 0.9e6)     # passive leak / VCS capacity\n        pexp= RNG.uniform(1.0, 2.5)\n        Topv= RNG.uniform(753., 893.)       # core-avg graphite temp at 9 MW\n        top = RNG.uniform(3, 60)*24*3600.   # prior operating time\n        p = dict(base); p.update(Mc=Mc,Mr=Mr,Gcr=Gcr,Grv=Grv,Q0=L0,L0=L0,\n                                 pexp=pexp,Top=Topv,t_op=top)\n        dr,_ = TR.make_drho(Tk, kk, Topv)\n        try:\n            so,_ = TR.run(p, dr, beta_eff)\n            ss = TR.summarize(so, p['P0'], Topv, dr)\n            rows.append((ss['trec']/3600 if ss['trec'] else np.nan,\n                         ss['P_stab']/1e3, ss['Tc_peak']-273, ss['Tv_peak']-273))\n        except Exception:\n            continue\n    G = np.array(rows)\n    trec = G[:,0][~np.isnan(G[:,0])]; pstab=G[:,1]; tcpk=G[:,2]; tvpk=G[:,3]\n    pc = lambda a,q: float(np.percentile(a,q))\n    print(f\"  recriticality time: median {np.median(trec):.1f} h, \"\n          f\"P10-P90 [{pc(trec,10):.1f}, {pc(trec,90):.1f}] h (min {trec.min():.1f}, max {trec.max():.1f})\")\n    print(f\"  stabilized fission power: median {np.median(pstab):.0f} kW, \"\n          f\"[{pc(pstab,10):.0f}, {pc(pstab,90):.0f}] kW\")\n    print(f\"  peak core graphite temp: median {np.median(tcpk):.0f} C, \"\n          f\"[{pc(tcpk,10):.0f}, {pc(tcpk,90):.0f}] C, max {tcpk.max():.0f} C\")\n    print(f\"  peak vessel temp: median {np.median(tvpk):.0f} C, max {tvpk.max():.0f} C\")\n\n    # ---------- Plot ----------\n    fig, ax = plt.subplots(2,1, figsize=(8,7), sharex=True)\n    t = sol.t/3600\n    ax[0].plot(t, sol.y[0]/1e6, 'b'); ax[0].set_yscale('log')\n    ax[0].set_ylabel('Fission power (MW)'); ax[0].grid(True, which='both', alpha=.3)\n    ax[0].axhline(9,ls='--',c='gray',lw=.8); ax[0].set_ylim(1e-4,20)\n    if s0['trec']: ax[0].axvline(s0['trec']/3600, ls=':', c='r', label=f\"recrit {s0['trec']/3600:.1f} h\")\n    ax[0].legend(); ax[0].set_title('HTTR LOFC (9 MWt, all circulators trip, no scram, VCS on) — computed')\n    ax[1].plot(t, sol.y[7]-273, 'r', label='core graphite (feedback)')\n    ax[1].plot(t, sol.y[8]-273, 'orange', label='reflector')\n    ax[1].plot(t, sol.y[9]-273, 'green', label='vessel (RPV)')\n    ax[1].axhline(Top-273, ls='--', c='k', lw=.8, label=f'T_op {Top-273:.0f} C')\n    ax[1].set_ylabel('Temperature (C)'); ax[1].set_xlabel('Time (h)')\n    ax[1].grid(True, alpha=.3); ax[1].legend(); ax[1].set_xlim(0, 120)\n    fig.tight_layout(); fig.savefig('output/lofc_transient.png', dpi=110)\n    print(\"\\nsaved output/lofc_transient.png\")\n\n    out = dict(k_T={float(T):[float(k),float(s)] for T,k,s in zip(Tk,kk,sk)},\n               alpha_T={float(T):[float(a),float(s)] for T,a,s in zip(Tq,am,asd)},\n               k_T_nobp={float(T):[float(k),float(s)] for T,k,s in zip(Tk2,kk2,sk2)},\n               alpha_T_nobp={float(T):[float(a),float(s)] for T,a,s in zip(Tq2,am2,asd2)},\n               alpha_bracket_pcmK=[min(a_on,a_off),max(a_on,a_off)],\n               alpha_avg_on_pcmK=a_on, alpha_avg_off_pcmK=a_off,\n               beta_eff=float(beta_eff), beta_eff_sigma=float(beta_sig),\n               nominal=dict(Pmin_kW=float(s0['Pmin_early']/1e3),\n                            tmin_min=float(s0['tmin']/60),\n                            Tc_peak_C=float(s0['Tc_peak']-273),\n                            tpeak_h=float(s0['tpeak']/3600),\n                            trec_h=float(s0['trec']/3600) if s0['trec'] else None,\n                            Pstab_kW=float(s0['P_stab']/1e3),\n                            Tv_peak_C=float(s0['Tv_peak']-273),\n                            Tv_end_C=float(s0['Tv_end']-273)),\n               sens=dict(trec_h=[pc(trec,10),float(np.median(trec)),pc(trec,90),float(trec.min()),float(trec.max())],\n                         Pstab_kW=[pc(pstab,10),float(np.median(pstab)),pc(pstab,90)],\n                         Tcpeak_C=[pc(tcpk,10),float(np.median(tcpk)),pc(tcpk,90),float(tcpk.max())],\n                         Tvpeak_C=[float(np.median(tvpk)),float(tvpk.max())]))\n    json.dump(out, open('output/results.json','w'), indent=2)\n    print(\"saved output/results.json\")\n\nif __name__ == '__main__':\n    main()\n","numLines":166,"startLine":1,"totalLines":166}}}
