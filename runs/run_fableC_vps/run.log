{"type":"assistant","message":{"model":"claude-fable-5","id":"msg_018K766HZNbA2G38S1mQb95J","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01DXnesnHLohhDZ9WAEkPoQz","name":"Edit","input":{"replace_all":false,"file_path":"/root/bench/fableC/output/rccs_model.py","old_string":"def nu_churchill_chu(dT, T_film, L):\n    dT = max(abs(dT), 0.01)","new_string":"def nu_churchill_chu(dT, T_film, L):\n    dT = max(abs(dT), 0.01)\n    T_film = min(max(T_film, 220.0), 2500.0)"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1042,"cache_read_input_tokens":75053,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1042},"output_tokens":2,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7fc4db3d-4032-4670-a03a-0a158c42f4ee","uuid":"0f0f1545-a994-4e17-963b-f305b153d0c3","request_id":"req_011CcfVQWLcGX6XtUCvSj7ZT"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DXnesnHLohhDZ9WAEkPoQz","type":"tool_result","content":"The file /root/bench/fableC/output/rccs_model.py has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"7fc4db3d-4032-4670-a03a-0a158c42f4ee","uuid":"c1da87b2-c55a-463e-b6f6-37498cbebb54","timestamp":"2026-07-03T17:07:24.181Z","tool_use_result":{"filePath":"/root/bench/fableC/output/rccs_model.py","oldString":"def nu_churchill_chu(dT, T_film, L):\n    dT = max(abs(dT), 0.01)","newString":"def nu_churchill_chu(dT, T_film, L):\n    dT = max(abs(dT), 0.01)\n    T_film = min(max(T_film, 220.0), 2500.0)","originalFile":"\"\"\"Quasi-2D natural-circulation model of the 1/2-scale air-cooled RCCS facility.\n\nPhysics\n-------\n* Cavity radiation: per-axial-slice radiosity network (5 surface groups:\n  heated plate, riser front faces, riser side faces, riser rear faces,\n  adiabatic insulated walls) with Monte-Carlo view factors (viewfactors.py).\n* Cavity gas convection: Churchill-Chu vertical-surface natural convection\n  (Churchill & Chu 1975; Incropera eq. 9.26) between plate / riser exterior\n  faces and a well-mixed cavity-air node.\n* Riser internal convection: Gnielinski (1976) with a (Tw/Tb)^-0.5\n  property-ratio correction for gas heating (Kays & Crawford).\n* Duct wall: per-face nodes coupled by wall conduction and by internal\n  front<->rear radiation.\n* Loop hydraulics: buoyancy integral over downcomer / risers / outlet\n  plenum / chimney vs. friction (Colebrook smooth-tube) + form losses\n  (Idelchik-style K values). Mass flow from a 1-D momentum balance.\n* Parasitic losses: conduction through heater back board and through the\n  6-in cavity wall insulation.\n\nAll dimensions from inputs/01, materials from inputs/02.\n\"\"\"\nimport numpy as np\nfrom scipy.optimize import brentq\nimport airprops as air\nfrom viewfactors import get_F\n\nSIG = 5.670374419e-8\nG = 9.81\n\n# ---------------------------------------------------------------- geometry\nN_SL = 10                      # axial slices (match 10 heater zones)\nL_HEAT = 6.91                  # riser length inside heated cavity, m (272 in)\nL_RISER = 7.49                 # total riser length, m (295 in)\nW_CAV = 1.3208                 # cavity width, m\nH_PLATE = 6.7                  # heated plate height, m\nA_PLATE = W_CAV * H_PLATE      # 8.85 m^2 geometric (as-built listed 10.18)\nEPS_PLATE = 0.785              # measured 0.78-0.79\nEPS_RISER = 0.80               # oxidized structural steel (assumed, +-0.10)\n\n# riser duct (per duct)\nDUCT_WI = 0.04125              # internal narrow dimension, m (1.624 in)\nDUCT_DI = 0.24445              # internal wide dimension, m (9.624 in)\nT_WALL = 0.004775              # wall, m (0.188 in)\nK_STEEL = 50.0\nA_INT = DUCT_WI * DUCT_DI      # 0.010083 m^2\nPER_INT = 2 * (DUCT_WI + DUCT_DI)\nDH = 4 * A_INT / PER_INT       # 0.0706 m\nN_DUCT = 12\nA_FLOW = N_DUCT * A_INT        # 0.121 m^2\n\n# exterior per-unit-height widths per group (all 12 ducts)\nW_EXT = {\"front\": N_DUCT * 0.0508, \"side\": 2 * N_DUCT * 0.254,\n         \"rear\": N_DUCT * 0.0508}\n# interior per-unit-height widths per group\nW_INT = {\"front\": N_DUCT * DUCT_WI, \"side\": 2 * N_DUCT * DUCT_DI,\n         \"rear\": N_DUCT * DUCT_WI}\n\n# wall conduction between face groups, W/K per m of height (all ducts):\n# 2 paths per duct per junction, path length = half front + half side face\nCOND_FS = N_DUCT * 2 * K_STEEL * T_WALL / (0.0508 / 2 + 0.254 / 2)  # front-side\nCOND_RS = COND_FS                                                    # rear-side\n\n# internal front<->rear radiation: parallel plates, eps_eff\nEPS_IN = 1.0 / (1 / 0.8 + 1 / 0.8 - 1)   # 0.667\nF_FR_IN = 0.82                            # front->rear view factor (2-D strips,\n                                          # w=0.244 m, gap=0.041 m)\n\n# loop elevations (z above inlet-plenum floor), m\nZ_RISER_IN = 0.94       # riser inlet (7 in below plenum ceiling of 44 in)\nZ_HEAT_BOT = 1.12       # heated cavity bottom = inlet plenum ceiling\nZ_RISER_TOP = Z_RISER_IN + L_RISER            # 8.43\nZ_CHIM_PORT = (Z_RISER_TOP - 0.406) + 1.435   # plenum floor + 56.5 in = 9.46\nZ_DISCHARGE = 19.6      # baseline chimney discharge height\nZ_DC_IN = 4.0           # downcomer inlet elevation (assumed)\n\n# flow-path sections\nA_DC = np.pi * 0.61 ** 2 / 4           # downcomer, single 24-in duct\nL_DC = 4.69                            # equivalent length, m (184.5 in)\nK_DC = 2.3                             # entrance + flow conditioner + elbow\nK_RISER_IN = 0.8                       # re-entrant duct inlet\nK_RISER_OUT = 1.0                      # discharge into large plenum\nA_CHIM = 0.58                          # both stacks\nA_STACK = A_CHIM / 2\nL_CHIM = 32.9                          # equivalent length per stack (826+470 in)\nD_CHIM = 0.61\nK_CHIM = 0.5 + 0.75 + 1.0              # port entrance + dampers + exit\nUA_CHIM_PER_M = 1.06                   # W/K per m per stack (3-in Enerwrap)\nL_CHIM_VERT = Z_DISCHARGE - Z_CHIM_PORT\n\n# insulation / parasitic\nA_CAVWALL = (2 * 1.0106 + W_CAV) * H_PLATE   # N/S/W inner faces, ~22.4 m^2\nTH_ISO = 0.152\nA_HEATER = A_PLATE\nTH_DUR = 0.0508\nEPS_EFF_HTR = 1.0 / (1 / 0.90 + 1 / EPS_PLATE - 1)\nH_OUT = 8.0                                   # room-side film coefficient\n\nDZ = L_HEAT / N_SL\nF_MAT, AREAS = get_F()\nEPS_VEC = np.array([EPS_PLATE, EPS_RISER, EPS_RISER, EPS_RISER, 0.85])\n\n\ndef k_superisol(T):\n    return np.interp(T, [473, 673, 873], [0.060, 0.080, 0.100])\n\n\ndef k_duraboard(T):\n    return np.interp(T, [477, 811], [0.079, 0.122])\n\n\ndef fric(Re):\n    Re = max(Re, 100.0)\n    if Re < 2300:\n        return 64.0 / Re\n    return (0.790 * np.log(Re) - 1.64) ** -2   # Petukhov, smooth\n\n\ndef nu_churchill_chu(dT, T_film, L):\n    dT = max(abs(dT), 0.01)\n    b = 1.0 / T_film\n    nu_k = air.mu(T_film) / air.rho(T_film)\n    Ra = G * b * dT * L ** 3 / (nu_k * (nu_k / air.Pr(T_film)))\n    Pr = air.Pr(T_film)\n    Nu = (0.825 + 0.387 * Ra ** (1 / 6)\n          / (1 + (0.492 / Pr) ** (9 / 16)) ** (8 / 27)) ** 2\n    return Nu * air.k(T_film) / L\n\n\ndef h_int_gnielinski(m_dot, T_b, T_w):\n    Gm = m_dot / A_FLOW\n    Re = Gm * DH / air.mu(T_b)\n    Pr = air.Pr(T_b)\n    if Re < 2300:\n        Nu = 4.36\n    else:\n        f = fric(Re)\n        Nu = (f / 8) * (Re - 1000) * Pr / (1 + 12.7 * np.sqrt(f / 8) * (Pr ** (2 / 3) - 1))\n    Nu *= (max(T_w, T_b + 1) / T_b) ** -0.5     # gas heating correction\n    return Nu * air.k(T_b) / DH, Re\n\n\ndef radiosity_slice(q_plate, T_faces):\n    \"\"\"Radiosity solve for one slice.\n\n    q_plate  : specified net radiative flux leaving plate, W/m^2\n    T_faces  : (T_front, T_side, T_rear) K\n    returns  : T_plate, net flux ABSORBED per unit area by each riser group,\n               adiabatic-wall surface temperature\n    \"\"\"\n    n = 5\n    A = np.zeros((n, n))\n    b = np.zeros(n)\n    # plate: flux-specified\n    A[0] = -F_MAT[0]\n    A[0, 0] += 1.0\n    b[0] = q_plate\n    # riser faces: temperature-specified\n    for i, T in zip((1, 2, 3), T_faces):\n        A[i] = -(1 - EPS_VEC[i]) * F_MAT[i]\n        A[i, i] += 1.0\n        b[i] = EPS_VEC[i] * SIG * T ** 4\n    # adiabatic wall: zero net flux\n    A[4] = -F_MAT[4]\n    A[4, 4] += 1.0\n    b[4] = 0.0\n    J = np.linalg.solve(A, b)\n    H = F_MAT @ J\n    q_net = J - H                          # leaving, per unit area\n    Tp4 = (J[0] + q_plate * (1 - EPS_PLATE) / EPS_PLATE) / SIG\n    T_ad = (J[4] / SIG) ** 0.25\n    return Tp4 ** 0.25, -q_net[1], -q_net[2], -q_net[3], T_ad\n\n\ndef solve_thermal(m_dot, P_to_plate, T_in, T_bldg, T_plate_fixed=None):\n    \"\"\"March the heated section for a given loop mass flow.\n\n    P_to_plate: net heater power reaching the plate front, W (flux mode)\n    T_plate_fixed: if set (transient mode), plate is isothermal at this T and\n    the returned dict contains the power the cavity removes from it.\n    \"\"\"\n    q_pl = P_to_plate / A_PLATE if T_plate_fixed is None else None\n    T_cav_lo, T_cav_hi = T_in + 1.0, 1500.0\n\n    def cavity_residual(T_cav, want=False):\n        T_air = T_in\n        Tf = Ts = Tr = T_air + 40\n        prof = []\n        Q_pl_conv = Q_ext_conv = Q_rad_ris = Q_wall = 0.0\n        Q_removed = 0.0\n        for i in range(N_SL):\n            h_i, Re = h_int_gnielinski(m_dot, T_air, Tf)\n            for _ in range(60):\n                if T_plate_fixed is None:\n                    # plate: flux-specified; subtract its convection first\n                    Tp_guess = prof[-1][\"Tp\"] if prof and _ == 0 else None\n                    Tp_it = Tp_guess or (Tf + 250)\n                    for _k in range(8):\n                        h_pl = nu_churchill_chu(Tp_it - T_cav,\n                                                (Tp_it + T_cav) / 2, H_PLATE)\n                        q_rad = q_pl - h_pl * (Tp_it - T_cav)\n                        Tp_new, qf, qs, qr, T_ad = radiosity_slice(\n                            q_rad, (Tf, Ts, Tr))\n                        Tp_it += 0.7 * (Tp_new - Tp_it)\n                    Tp = Tp_it\n                else:\n                    Tp = T_plate_fixed\n                    h_pl = nu_churchill_chu(Tp - T_cav, (Tp + T_cav) / 2,\n                                            H_PLATE)\n                    # temperature-specified plate: replace flux eq. by T eq.\n                    qf, qs, qr, T_ad, q_rad = _rad_T_plate(Tp, (Tf, Ts, Tr))\n                # exterior natural convection on riser faces\n                h_ext = {}\n                for key, T in ((\"front\", Tf), (\"side\", Ts), (\"rear\", Tr)):\n                    h_ext[key] = nu_churchill_chu(T_cav - T, (T + T_cav) / 2,\n                                                  H_PLATE)\n                # internal front<->rear radiation\n                q_fr = EPS_IN * F_FR_IN * SIG * (Tf ** 4 - Tr ** 4)\n                A_fr = W_INT[\"front\"] * DZ\n                # face balances -> new temps\n                def face_T(q_rad_a, key, T_old, extra):\n                    A_e = W_EXT[key] * DZ\n                    A_i = W_INT[key] * DZ\n                    Q = q_rad_a * A_e + h_ext[key] * A_e * (T_cav - T_old) + extra\n                    return T_air + Q / (h_i * A_i)\n                cond_f = COND_FS * DZ * (Ts - Tf)\n                cond_r = COND_RS * DZ * (Ts - Tr)\n                Tf_n = face_T(qf, \"front\", Tf, cond_f - q_fr * A_fr)\n                Ts_n = face_T(qs, \"side\", Ts, -cond_f - cond_r)\n                Tr_n = face_T(qr, \"rear\", Tr, cond_r + q_fr * A_fr)\n                dmax = max(abs(Tf_n - Tf), abs(Ts_n - Ts), abs(Tr_n - Tr))\n                Tf += 0.6 * (Tf_n - Tf)\n                Ts += 0.6 * (Ts_n - Ts)\n                Tr += 0.6 * (Tr_n - Tr)\n                if dmax < 0.02:\n                    break\n            # slice heat into the air\n            Q_i = h_i * DZ * (W_INT[\"front\"] * (Tf - T_air)\n                              + W_INT[\"side\"] * (Ts - T_air)\n                              + W_INT[\"rear\"] * (Tr - T_air))\n            cp = air.cp(T_air)\n            prof.append(dict(z=(i + 0.5) * DZ, Tp=Tp, Tf=Tf, Ts=Ts, Tr=Tr,\n                             Tair=T_air, Tad=T_ad, h_i=h_i, Re=Re,\n                             qf=qf, qs=qs, qr=qr,\n                             h_ext=dict(h_ext), h_pl=h_pl, Qi=Q_i))\n            Q_removed += Q_i\n            Q_pl_conv += h_pl * (Tp - T_cav) * (A_PLATE / N_SL)\n            for key, T in ((\"front\", Tf), (\"side\", Ts), (\"rear\", Tr)):\n                Q_ext_conv += h_ext[key] * W_EXT[key] * DZ * (T_cav - T)\n                if key != \"rear\":\n                    pass\n            Q_rad_ris += (qf * W_EXT[\"front\"] + qs * W_EXT[\"side\"]\n                          + qr * W_EXT[\"rear\"]) * DZ\n            # cavity wall loss (through 6-in SuperIsol)\n            U_w = 1.0 / (TH_ISO / k_superisol(T_ad) + 1 / H_OUT)\n            Q_wall += U_w * (A_CAVWALL / N_SL) * (T_ad - T_bldg)\n            T_air = T_air + Q_i / (m_dot * cp)\n        # cavity air heat balance: plate conv in = riser ext conv + wall conv\n        h_w = 3.0  # cavity air <-> insulated walls film\n        res = Q_pl_conv - Q_ext_conv - h_w * A_CAVWALL * (\n            T_cav - np.mean([p[\"Tad\"] for p in prof]))\n        if want:\n            return prof, T_air, Q_removed, Q_wall, Q_pl_conv, Q_ext_conv, Q_rad_ris\n        return res\n\n    T_cav = brentq(cavity_residual, T_cav_lo, T_cav_hi, xtol=0.05)\n    prof, T_out, Q_rem, Q_wall, Qpc, Qec, Qrr = cavity_residual(T_cav, want=True)\n    return dict(T_cav=T_cav, prof=prof, T_out=T_out, Q_removed=Q_rem,\n                Q_wall=Q_wall, Q_plate_conv=Qpc, Q_ext_conv=Qec,\n                Q_rad_risers=Qrr)\n\n\ndef _rad_T_plate(Tp, T_faces):\n    \"\"\"radiosity with ALL surfaces temperature-specified except adiabatic.\"\"\"\n    n = 5\n    A = np.zeros((n, n))\n    b = np.zeros(n)\n    Ts_all = [Tp, *T_faces]\n    for i in range(4):\n        A[i] = -(1 - EPS_VEC[i]) * F_MAT[i]\n        A[i, i] += 1.0\n        b[i] = EPS_VEC[i] * SIG * Ts_all[i] ** 4\n    A[4] = -F_MAT[4]\n    A[4, 4] += 1.0\n    J = np.linalg.solve(A, b)\n    H = F_MAT @ J\n    q = J - H\n    T_ad = (J[4] / SIG) ** 0.25\n    return -q[1], -q[2], -q[3], T_ad, q[0]\n\n\ndef loop_dp(m_dot, therm, T_in, T_out_gas, T_amb, wind=0.0, cp_wind=0.0):\n    \"\"\"buoyancy minus losses, Pa (positive drives flow).\"\"\"\n    rho_amb = air.rho(T_amb)\n    rho_in = air.rho(T_in)\n\n    # --- buoyancy: integral of rho*g*dz around the loop vs ambient column\n    drive = rho_amb * G * (Z_DISCHARGE - Z_DC_IN)\n    # downcomer + inlet plenum (descending, at T_in)\n    drive += rho_in * G * (Z_DC_IN - Z_RISER_IN)   # descending leg helps if dense\n    drive -= rho_in * G * 0.0\n    # actually: sum rho*g*dz over the upward path from riser inlet to discharge\n    col = 0.0\n    # unheated riser bottom\n    col += air.rho(T_in) * (Z_HEAT_BOT - Z_RISER_IN)\n    # heated riser\n    for p in therm[\"prof\"]:\n        col += air.rho(p[\"Tair\"]) * DZ\n    # unheated riser top + outlet plenum to chimney port\n    col += air.rho(T_out_gas) * (Z_RISER_TOP - (Z_HEAT_BOT + L_HEAT))\n    col += air.rho(T_out_gas) * (Z_CHIM_PORT - Z_RISER_TOP)\n    # chimney vertical, cooling along height (per stack m/2)\n    T = T_out_gas\n    nz = 20\n    dzc = L_CHIM_VERT / nz\n    cp = air.cp(T_out_gas)\n    for _ in range(nz):\n        col += air.rho(T) * dzc\n        T -= UA_CHIM_PER_M * dzc * (T - T_amb) / ((m_dot / 2) * cp)\n    T_stack_exit = T\n    drive -= col * G\n    # wind at the discharge (cp_wind > 0 reduces draft)\n    drive -= cp_wind * 0.5 * rho_amb * wind ** 2\n\n    # --- losses\n    dp = 0.0\n    v_dc = m_dot / (rho_in * A_DC)\n    Re_dc = rho_in * v_dc * 0.61 / air.mu(T_in)\n    dp += (fric(Re_dc) * L_DC / 0.61 + K_DC) * 0.5 * rho_in * v_dc ** 2\n    Gm = m_dot / A_FLOW\n    v_rin = Gm / rho_in\n    dp += K_RISER_IN * 0.5 * rho_in * v_rin ** 2\n    # riser friction (heated, per slice) + unheated ends\n    for p in therm[\"prof\"]:\n        rho_l = air.rho(p[\"Tair\"])\n        Re = Gm * DH / air.mu(p[\"Tair\"])\n        dp += fric(Re) * (DZ / DH) * Gm ** 2 / (2 * rho_l)\n    rho_o = air.rho(T_out_gas)\n    dp += fric(Gm * DH / air.mu(T_in)) * (0.18 / DH) * Gm ** 2 / (2 * rho_in)\n    dp += fric(Gm * DH / air.mu(T_out_gas)) * (0.40 / DH) * Gm ** 2 / (2 * rho_o)\n    # acceleration\n    dp += Gm ** 2 * (1 / rho_o - 1 / rho_in)\n    dp += K_RISER_OUT * 0.5 * rho_o * (Gm / rho_o) ** 2\n    # chimney (per stack)\n    v_ch = (m_dot / 2) / (rho_o * A_STACK)\n    Re_ch = rho_o * v_ch * D_CHIM / air.mu(T_out_gas)\n    dp += (fric(Re_ch) * L_CHIM / D_CHIM + K_CHIM) * 0.5 * rho_o * v_ch ** 2\n\n    return drive - dp, T_stack_exit\n\n\ndef solve_steady(P_elec=None, T_outdoor=275.15, T_bldg=293.15,\n                 T_inlet=None, wind=0.0, cp_wind=0.0, T_plate_fixed=None,\n                 verbose=False):\n    \"\"\"Full coupled solve. Either P_elec (W) or T_plate_fixed (K) given.\"\"\"\n    T_in = T_inlet if T_inlet is not None else T_bldg\n\n    Q_back = 0.0\n    Q_wall_prev = 0.0\n    result = None\n    for outer in range(8):\n        if T_plate_fixed is None:\n            P_to_plate = P_elec - Q_back - Q_wall_prev\n        else:\n            P_to_plate = None\n\n        def mom_residual(m_dot):\n            th = solve_thermal(m_dot, P_to_plate, T_in, T_bldg,\n                               T_plate_fixed=T_plate_fixed)\n            r, _ = loop_dp(m_dot, th, T_in, th[\"T_out\"], T_outdoor,\n                           wind, cp_wind)\n            return r\n\n        m_dot = brentq(mom_residual, 0.02, 6.0, xtol=1e-4)\n        th = solve_thermal(m_dot, P_to_plate, T_in, T_bldg,\n                           T_plate_fixed=T_plate_fixed)\n        _, T_stack_exit = loop_dp(m_dot, th, T_in, th[\"T_out\"], T_outdoor,\n                                  wind, cp_wind)\n        # update parasitic losses\n        Tp_mean = np.mean([p[\"Tp\"] for p in th[\"prof\"]])\n        if T_plate_fixed is None:\n            q_gross = (P_elec - Q_back) / A_PLATE\n            T_pb = Tp_mean + q_gross * 0.0254 / K_STEEL\n            T_h = (T_pb ** 4 + q_gross / (SIG * EPS_EFF_HTR)) ** 0.25\n            R_back = TH_DUR / k_duraboard((T_h + T_bldg) / 2) + 1 / H_OUT\n            Q_back_new = A_HEATER * (T_h - T_bldg) / R_back\n        else:\n            T_h = Tp_mean\n            Q_back_new = Q_back\n        conv = (abs(Q_back_new - Q_back) < 20\n                and abs(th[\"Q_wall\"] - Q_wall_prev) < 20)\n        Q_back = Q_back_new\n        Q_wall_prev = th[\"Q_wall\"]\n        result = (m_dot, th, T_stack_exit, T_h)\n        if conv and outer > 1:\n            break\n\n    m_dot, th, T_stack_exit, T_h = result\n    prof = th[\"prof\"]\n    Tp_mean = np.mean([p[\"Tp\"] for p in prof])\n    # mid-plane values (z = 3.5 m -> between slices 5 and 6, interp)\n    zs = np.array([p[\"z\"] for p in prof])\n    def midp(key):\n        return float(np.interp(3.5, zs, [p[key] for p in prof]))\n    out = dict(\n        m_dot=m_dot, T_in=T_in, T_out=th[\"T_out\"], dT=th[\"T_out\"] - T_in,\n        T_cav=th[\"T_cav\"], Q_removed=th[\"Q_removed\"], Q_back=Q_back,\n        Q_wall=th[\"Q_wall\"], Tp_mean=Tp_mean, Tp_mid=midp(\"Tp\"),\n        Tp_max=max(p[\"Tp\"] for p in prof),\n        Tf_mid=midp(\"Tf\"), Ts_mid=midp(\"Ts\"), Tr_mid=midp(\"Tr\"),\n        Tair_mid=midp(\"Tair\"), T_heater=T_h, T_stack_exit=T_stack_exit,\n        Q_rad_risers=th[\"Q_rad_risers\"], Q_ext_conv=th[\"Q_ext_conv\"],\n        Q_plate_conv=th[\"Q_plate_conv\"], prof=prof,\n        Re_mid=midp(\"Re\"), h_i_mid=midp(\"h_i\"),\n        qf_mid=midp(\"qf\"), qs_mid=midp(\"qs\"), qr_mid=midp(\"qr\"),\n    )\n    if verbose:\n        _print(out)\n    return out\n\n\ndef _print(o):\n    print(f\"m_dot        = {o['m_dot']:.3f} kg/s ({o['m_dot']*60:.1f} kg/min)\")\n    print(f\"T_in/T_out   = {o['T_in']-273.15:.1f} / {o['T_out']-273.15:.1f} C\"\n          f\"   dT = {o['dT']:.1f} K\")\n    print(f\"T_cav        = {o['T_cav']-273.15:.1f} C\")\n    print(f\"plate: mean {o['Tp_mean']-273.15:.0f} C, mid {o['Tp_mid']-273.15:.0f} C,\"\n          f\" max {o['Tp_max']-273.15:.0f} C ; heater {o['T_heater']-273.15:.0f} C\")\n    print(f\"riser7 mid-plane: front {o['Tf_mid']-273.15:.1f} C,\"\n          f\" side {o['Ts_mid']-273.15:.1f} C, rear {o['Tr_mid']-273.15:.1f} C,\"\n          f\" air {o['Tair_mid']-273.15:.1f} C\")\n    print(f\"Q_removed(air) = {o['Q_removed']/1e3:.1f} kW; Q_back = \"\n          f\"{o['Q_back']/1e3:.1f} kW; Q_cavwall = {o['Q_wall']/1e3:.1f} kW\")\n    print(f\"radiation to risers = {o['Q_rad_risers']/1e3:.1f} kW; \"\n          f\"ext conv to risers = {o['Q_ext_conv']/1e3:.1f} kW; \"\n          f\"plate conv = {o['Q_plate_conv']/1e3:.1f} kW\")\n    print(f\"Re_mid = {o['Re_mid']:.0f}, h_int mid = {o['h_i_mid']:.1f} W/m2K\")\n    print(f\"stack exit T = {o['T_stack_exit']-273.15:.1f} C\")\n\n\nif __name__ == \"__main__\":\n    print(\"=== Case 1: baseline, 82 kWe, outdoor 2 C, building 20 C ===\")\n    solve_steady(P_elec=82e3, T_outdoor=275.15, T_bldg=293.15, verbose=True)\n","structuredPatch":[{"oldStart":118,"oldLines":6,"newStart":118,"newLines":7,"lines":[" "," def nu_churchill_chu(dT, T_film, L):","     dT = max(abs(dT), 0.01)","+    T_film = min(max(T_film, 220.0), 2500.0)","     b = 1.0 / T_film","     nu_k = air.mu(T_film) / air.rho(T_film)","     Ra = G * b * dT * L ** 3 / (nu_k * (nu_k / air.Pr(T_film)))"]}],"userModified":false,"replaceAll":false}}
{"type":"assistant","message":{"model":"claude-fable-5","id":"msg_018K766HZNbA2G38S1mQb95J","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WvmSryBgNf8Bgm3ecVe6oM","name":"Edit","input":{"replace_all":false,"file_path":"/root/bench/fableC/output/rccs_model.py","old_string":"                Tf += 0.6 * (Tf_n - Tf)\n                Ts += 0.6 * (Ts_n - Ts)\n                Tr += 0.6 * (Tr_n - Tr)","new_string":"                clip = lambda T: min(max(T, 220.0), 2200.0)\n                Tf = clip(Tf + 0.6 * (Tf_n - Tf))\n                Ts = clip(Ts + 0.6 * (Ts_n - Ts))\n                Tr = clip(Tr + 0.6 * (Tr_n - Tr))"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1042,"cache_read_input_tokens":75053,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1042},"output_tokens":2,"service_tier":"standard","inference_geo":"global"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7fc4db3d-4032-4670-a03a-0a158c42f4ee","uuid":"b3354748-df63-498e-948d-479c6da7f27c","request_id":"req_011CcfVQWLcGX6XtUCvSj7ZT"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WvmSryBgNf8Bgm3ecVe6oM","type":"tool_result","content":"The file /root/bench/fableC/output/rccs_model.py has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"7fc4db3d-4032-4670-a03a-0a158c42f4ee","uuid":"95325c8d-64d3-4b62-9861-4bbe7a7fe713","timestamp":"2026-07-03T17:07:26.528Z","tool_use_result":{"filePath":"/root/bench/fableC/output/rccs_model.py","oldString":"                Tf += 0.6 * (Tf_n - Tf)\n                Ts += 0.6 * (Ts_n - Ts)\n                Tr += 0.6 * (Tr_n - Tr)","newString":"                clip = lambda T: min(max(T, 220.0), 2200.0)\n                Tf = clip(Tf + 0.6 * (Tf_n - Tf))\n                Ts = clip(Ts + 0.6 * (Ts_n - Ts))\n                Tr = clip(Tr + 0.6 * (Tr_n - Tr))","originalFile":"\"\"\"Quasi-2D natural-circulation model of the 1/2-scale air-cooled RCCS facility.\n\nPhysics\n-------\n* Cavity radiation: per-axial-slice radiosity network (5 surface groups:\n  heated plate, riser front faces, riser side faces, riser rear faces,\n  adiabatic insulated walls) with Monte-Carlo view factors (viewfactors.py).\n* Cavity gas convection: Churchill-Chu vertical-surface natural convection\n  (Churchill & Chu 1975; Incropera eq. 9.26) between plate / riser exterior\n  faces and a well-mixed cavity-air node.\n* Riser internal convection: Gnielinski (1976) with a (Tw/Tb)^-0.5\n  property-ratio correction for gas heating (Kays & Crawford).\n* Duct wall: per-face nodes coupled by wall conduction and by internal\n  front<->rear radiation.\n* Loop hydraulics: buoyancy integral over downcomer / risers / outlet\n  plenum / chimney vs. friction (Colebrook smooth-tube) + form losses\n  (Idelchik-style K values). Mass flow from a 1-D momentum balance.\n* Parasitic losses: conduction through heater back board and through the\n  6-in cavity wall insulation.\n\nAll dimensions from inputs/01, materials from inputs/02.\n\"\"\"\nimport numpy as np\nfrom scipy.optimize import brentq\nimport airprops as air\nfrom viewfactors import get_F\n\nSIG = 5.670374419e-8\nG = 9.81\n\n# ---------------------------------------------------------------- geometry\nN_SL = 10                      # axial slices (match 10 heater zones)\nL_HEAT = 6.91                  # riser length inside heated cavity, m (272 in)\nL_RISER = 7.49                 # total riser length, m (295 in)\nW_CAV = 1.3208                 # cavity width, m\nH_PLATE = 6.7                  # heated plate height, m\nA_PLATE = W_CAV * H_PLATE      # 8.85 m^2 geometric (as-built listed 10.18)\nEPS_PLATE = 0.785              # measured 0.78-0.79\nEPS_RISER = 0.80               # oxidized structural steel (assumed, +-0.10)\n\n# riser duct (per duct)\nDUCT_WI = 0.04125              # internal narrow dimension, m (1.624 in)\nDUCT_DI = 0.24445              # internal wide dimension, m (9.624 in)\nT_WALL = 0.004775              # wall, m (0.188 in)\nK_STEEL = 50.0\nA_INT = DUCT_WI * DUCT_DI      # 0.010083 m^2\nPER_INT = 2 * (DUCT_WI + DUCT_DI)\nDH = 4 * A_INT / PER_INT       # 0.0706 m\nN_DUCT = 12\nA_FLOW = N_DUCT * A_INT        # 0.121 m^2\n\n# exterior per-unit-height widths per group (all 12 ducts)\nW_EXT = {\"front\": N_DUCT * 0.0508, \"side\": 2 * N_DUCT * 0.254,\n         \"rear\": N_DUCT * 0.0508}\n# interior per-unit-height widths per group\nW_INT = {\"front\": N_DUCT * DUCT_WI, \"side\": 2 * N_DUCT * DUCT_DI,\n         \"rear\": N_DUCT * DUCT_WI}\n\n# wall conduction between face groups, W/K per m of height (all ducts):\n# 2 paths per duct per junction, path length = half front + half side face\nCOND_FS = N_DUCT * 2 * K_STEEL * T_WALL / (0.0508 / 2 + 0.254 / 2)  # front-side\nCOND_RS = COND_FS                                                    # rear-side\n\n# internal front<->rear radiation: parallel plates, eps_eff\nEPS_IN = 1.0 / (1 / 0.8 + 1 / 0.8 - 1)   # 0.667\nF_FR_IN = 0.82                            # front->rear view factor (2-D strips,\n                                          # w=0.244 m, gap=0.041 m)\n\n# loop elevations (z above inlet-plenum floor), m\nZ_RISER_IN = 0.94       # riser inlet (7 in below plenum ceiling of 44 in)\nZ_HEAT_BOT = 1.12       # heated cavity bottom = inlet plenum ceiling\nZ_RISER_TOP = Z_RISER_IN + L_RISER            # 8.43\nZ_CHIM_PORT = (Z_RISER_TOP - 0.406) + 1.435   # plenum floor + 56.5 in = 9.46\nZ_DISCHARGE = 19.6      # baseline chimney discharge height\nZ_DC_IN = 4.0           # downcomer inlet elevation (assumed)\n\n# flow-path sections\nA_DC = np.pi * 0.61 ** 2 / 4           # downcomer, single 24-in duct\nL_DC = 4.69                            # equivalent length, m (184.5 in)\nK_DC = 2.3                             # entrance + flow conditioner + elbow\nK_RISER_IN = 0.8                       # re-entrant duct inlet\nK_RISER_OUT = 1.0                      # discharge into large plenum\nA_CHIM = 0.58                          # both stacks\nA_STACK = A_CHIM / 2\nL_CHIM = 32.9                          # equivalent length per stack (826+470 in)\nD_CHIM = 0.61\nK_CHIM = 0.5 + 0.75 + 1.0              # port entrance + dampers + exit\nUA_CHIM_PER_M = 1.06                   # W/K per m per stack (3-in Enerwrap)\nL_CHIM_VERT = Z_DISCHARGE - Z_CHIM_PORT\n\n# insulation / parasitic\nA_CAVWALL = (2 * 1.0106 + W_CAV) * H_PLATE   # N/S/W inner faces, ~22.4 m^2\nTH_ISO = 0.152\nA_HEATER = A_PLATE\nTH_DUR = 0.0508\nEPS_EFF_HTR = 1.0 / (1 / 0.90 + 1 / EPS_PLATE - 1)\nH_OUT = 8.0                                   # room-side film coefficient\n\nDZ = L_HEAT / N_SL\nF_MAT, AREAS = get_F()\nEPS_VEC = np.array([EPS_PLATE, EPS_RISER, EPS_RISER, EPS_RISER, 0.85])\n\n\ndef k_superisol(T):\n    return np.interp(T, [473, 673, 873], [0.060, 0.080, 0.100])\n\n\ndef k_duraboard(T):\n    return np.interp(T, [477, 811], [0.079, 0.122])\n\n\ndef fric(Re):\n    Re = max(Re, 100.0)\n    if Re < 2300:\n        return 64.0 / Re\n    return (0.790 * np.log(Re) - 1.64) ** -2   # Petukhov, smooth\n\n\ndef nu_churchill_chu(dT, T_film, L):\n    dT = max(abs(dT), 0.01)\n    T_film = min(max(T_film, 220.0), 2500.0)\n    b = 1.0 / T_film\n    nu_k = air.mu(T_film) / air.rho(T_film)\n    Ra = G * b * dT * L ** 3 / (nu_k * (nu_k / air.Pr(T_film)))\n    Pr = air.Pr(T_film)\n    Nu = (0.825 + 0.387 * Ra ** (1 / 6)\n          / (1 + (0.492 / Pr) ** (9 / 16)) ** (8 / 27)) ** 2\n    return Nu * air.k(T_film) / L\n\n\ndef h_int_gnielinski(m_dot, T_b, T_w):\n    Gm = m_dot / A_FLOW\n    Re = Gm * DH / air.mu(T_b)\n    Pr = air.Pr(T_b)\n    if Re < 2300:\n        Nu = 4.36\n    else:\n        f = fric(Re)\n        Nu = (f / 8) * (Re - 1000) * Pr / (1 + 12.7 * np.sqrt(f / 8) * (Pr ** (2 / 3) - 1))\n    Nu *= (max(T_w, T_b + 1) / T_b) ** -0.5     # gas heating correction\n    return Nu * air.k(T_b) / DH, Re\n\n\ndef radiosity_slice(q_plate, T_faces):\n    \"\"\"Radiosity solve for one slice.\n\n    q_plate  : specified net radiative flux leaving plate, W/m^2\n    T_faces  : (T_front, T_side, T_rear) K\n    returns  : T_plate, net flux ABSORBED per unit area by each riser group,\n               adiabatic-wall surface temperature\n    \"\"\"\n    n = 5\n    A = np.zeros((n, n))\n    b = np.zeros(n)\n    # plate: flux-specified\n    A[0] = -F_MAT[0]\n    A[0, 0] += 1.0\n    b[0] = q_plate\n    # riser faces: temperature-specified\n    for i, T in zip((1, 2, 3), T_faces):\n        A[i] = -(1 - EPS_VEC[i]) * F_MAT[i]\n        A[i, i] += 1.0\n        b[i] = EPS_VEC[i] * SIG * T ** 4\n    # adiabatic wall: zero net flux\n    A[4] = -F_MAT[4]\n    A[4, 4] += 1.0\n    b[4] = 0.0\n    J = np.linalg.solve(A, b)\n    H = F_MAT @ J\n    q_net = J - H                          # leaving, per unit area\n    Tp4 = (J[0] + q_plate * (1 - EPS_PLATE) / EPS_PLATE) / SIG\n    T_ad = (J[4] / SIG) ** 0.25\n    return Tp4 ** 0.25, -q_net[1], -q_net[2], -q_net[3], T_ad\n\n\ndef solve_thermal(m_dot, P_to_plate, T_in, T_bldg, T_plate_fixed=None):\n    \"\"\"March the heated section for a given loop mass flow.\n\n    P_to_plate: net heater power reaching the plate front, W (flux mode)\n    T_plate_fixed: if set (transient mode), plate is isothermal at this T and\n    the returned dict contains the power the cavity removes from it.\n    \"\"\"\n    q_pl = P_to_plate / A_PLATE if T_plate_fixed is None else None\n    T_cav_lo, T_cav_hi = T_in + 1.0, 1500.0\n\n    def cavity_residual(T_cav, want=False):\n        T_air = T_in\n        Tf = Ts = Tr = T_air + 40\n        prof = []\n        Q_pl_conv = Q_ext_conv = Q_rad_ris = Q_wall = 0.0\n        Q_removed = 0.0\n        for i in range(N_SL):\n            h_i, Re = h_int_gnielinski(m_dot, T_air, Tf)\n            for _ in range(60):\n                if T_plate_fixed is None:\n                    # plate: flux-specified; subtract its convection first\n                    Tp_guess = prof[-1][\"Tp\"] if prof and _ == 0 else None\n                    Tp_it = Tp_guess or (Tf + 250)\n                    for _k in range(8):\n                        h_pl = nu_churchill_chu(Tp_it - T_cav,\n                                                (Tp_it + T_cav) / 2, H_PLATE)\n                        q_rad = q_pl - h_pl * (Tp_it - T_cav)\n                        Tp_new, qf, qs, qr, T_ad = radiosity_slice(\n                            q_rad, (Tf, Ts, Tr))\n                        Tp_it += 0.7 * (Tp_new - Tp_it)\n                    Tp = Tp_it\n                else:\n                    Tp = T_plate_fixed\n                    h_pl = nu_churchill_chu(Tp - T_cav, (Tp + T_cav) / 2,\n                                            H_PLATE)\n                    # temperature-specified plate: replace flux eq. by T eq.\n                    qf, qs, qr, T_ad, q_rad = _rad_T_plate(Tp, (Tf, Ts, Tr))\n                # exterior natural convection on riser faces\n                h_ext = {}\n                for key, T in ((\"front\", Tf), (\"side\", Ts), (\"rear\", Tr)):\n                    h_ext[key] = nu_churchill_chu(T_cav - T, (T + T_cav) / 2,\n                                                  H_PLATE)\n                # internal front<->rear radiation\n                q_fr = EPS_IN * F_FR_IN * SIG * (Tf ** 4 - Tr ** 4)\n                A_fr = W_INT[\"front\"] * DZ\n                # face balances -> new temps\n                def face_T(q_rad_a, key, T_old, extra):\n                    A_e = W_EXT[key] * DZ\n                    A_i = W_INT[key] * DZ\n                    Q = q_rad_a * A_e + h_ext[key] * A_e * (T_cav - T_old) + extra\n                    return T_air + Q / (h_i * A_i)\n                cond_f = COND_FS * DZ * (Ts - Tf)\n                cond_r = COND_RS * DZ * (Ts - Tr)\n                Tf_n = face_T(qf, \"front\", Tf, cond_f - q_fr * A_fr)\n                Ts_n = face_T(qs, \"side\", Ts, -cond_f - cond_r)\n                Tr_n = face_T(qr, \"rear\", Tr, cond_r + q_fr * A_fr)\n                dmax = max(abs(Tf_n - Tf), abs(Ts_n - Ts), abs(Tr_n - Tr))\n                Tf += 0.6 * (Tf_n - Tf)\n                Ts += 0.6 * (Ts_n - Ts)\n                Tr += 0.6 * (Tr_n - Tr)\n                if dmax < 0.02:\n                    break\n            # slice heat into the air\n            Q_i = h_i * DZ * (W_INT[\"front\"] * (Tf - T_air)\n                              + W_INT[\"side\"] * (Ts - T_air)\n                              + W_INT[\"rear\"] * (Tr - T_air))\n            cp = air.cp(T_air)\n            prof.append(dict(z=(i + 0.5) * DZ, Tp=Tp, Tf=Tf, Ts=Ts, Tr=Tr,\n                             Tair=T_air, Tad=T_ad, h_i=h_i, Re=Re,\n                             qf=qf, qs=qs, qr=qr,\n                             h_ext=dict(h_ext), h_pl=h_pl, Qi=Q_i))\n            Q_removed += Q_i\n            Q_pl_conv += h_pl * (Tp - T_cav) * (A_PLATE / N_SL)\n            for key, T in ((\"front\", Tf), (\"side\", Ts), (\"rear\", Tr)):\n                Q_ext_conv += h_ext[key] * W_EXT[key] * DZ * (T_cav - T)\n                if key != \"rear\":\n                    pass\n            Q_rad_ris += (qf * W_EXT[\"front\"] + qs * W_EXT[\"side\"]\n                          + qr * W_EXT[\"rear\"]) * DZ\n            # cavity wall loss (through 6-in SuperIsol)\n            U_w = 1.0 / (TH_ISO / k_superisol(T_ad) + 1 / H_OUT)\n            Q_wall += U_w * (A_CAVWALL / N_SL) * (T_ad - T_bldg)\n            T_air = T_air + Q_i / (m_dot * cp)\n        # cavity air heat balance: plate conv in = riser ext conv + wall conv\n        h_w = 3.0  # cavity air <-> insulated walls film\n        res = Q_pl_conv - Q_ext_conv - h_w * A_CAVWALL * (\n            T_cav - np.mean([p[\"Tad\"] for p in prof]))\n        if want:\n            return prof, T_air, Q_removed, Q_wall, Q_pl_conv, Q_ext_conv, Q_rad_ris\n        return res\n\n    T_cav = brentq(cavity_residual, T_cav_lo, T_cav_hi, xtol=0.05)\n    prof, T_out, Q_rem, Q_wall, Qpc, Qec, Qrr = cavity_residual(T_cav, want=True)\n    return dict(T_cav=T_cav, prof=prof, T_out=T_out, Q_removed=Q_rem,\n                Q_wall=Q_wall, Q_plate_conv=Qpc, Q_ext_conv=Qec,\n                Q_rad_risers=Qrr)\n\n\ndef _rad_T_plate(Tp, T_faces):\n    \"\"\"radiosity with ALL surfaces temperature-specified except adiabatic.\"\"\"\n    n = 5\n    A = np.zeros((n, n))\n    b = np.zeros(n)\n    Ts_all = [Tp, *T_faces]\n    for i in range(4):\n        A[i] = -(1 - EPS_VEC[i]) * F_MAT[i]\n        A[i, i] += 1.0\n        b[i] = EPS_VEC[i] * SIG * Ts_all[i] ** 4\n    A[4] = -F_MAT[4]\n    A[4, 4] += 1.0\n    J = np.linalg.solve(A, b)\n    H = F_MAT @ J\n    q = J - H\n    T_ad = (J[4] / SIG) ** 0.25\n    return -q[1], -q[2], -q[3], T_ad, q[0]\n\n\ndef loop_dp(m_dot, therm, T_in, T_out_gas, T_amb, wind=0.0, cp_wind=0.0):\n    \"\"\"buoyancy minus losses, Pa (positive drives flow).\"\"\"\n    rho_amb = air.rho(T_amb)\n    rho_in = air.rho(T_in)\n\n    # --- buoyancy: integral of rho*g*dz around the loop vs ambient column\n    drive = rho_amb * G * (Z_DISCHARGE - Z_DC_IN)\n    # downcomer + inlet plenum (descending, at T_in)\n    drive += rho_in * G * (Z_DC_IN - Z_RISER_IN)   # descending leg helps if dense\n    drive -= rho_in * G * 0.0\n    # actually: sum rho*g*dz over the upward path from riser inlet to discharge\n    col = 0.0\n    # unheated riser bottom\n    col += air.rho(T_in) * (Z_HEAT_BOT - Z_RISER_IN)\n    # heated riser\n    for p in therm[\"prof\"]:\n        col += air.rho(p[\"Tair\"]) * DZ\n    # unheated riser top + outlet plenum to chimney port\n    col += air.rho(T_out_gas) * (Z_RISER_TOP - (Z_HEAT_BOT + L_HEAT))\n    col += air.rho(T_out_gas) * (Z_CHIM_PORT - Z_RISER_TOP)\n    # chimney vertical, cooling along height (per stack m/2)\n    T = T_out_gas\n    nz = 20\n    dzc = L_CHIM_VERT / nz\n    cp = air.cp(T_out_gas)\n    for _ in range(nz):\n        col += air.rho(T) * dzc\n        T -= UA_CHIM_PER_M * dzc * (T - T_amb) / ((m_dot / 2) * cp)\n    T_stack_exit = T\n    drive -= col * G\n    # wind at the discharge (cp_wind > 0 reduces draft)\n    drive -= cp_wind * 0.5 * rho_amb * wind ** 2\n\n    # --- losses\n    dp = 0.0\n    v_dc = m_dot / (rho_in * A_DC)\n    Re_dc = rho_in * v_dc * 0.61 / air.mu(T_in)\n    dp += (fric(Re_dc) * L_DC / 0.61 + K_DC) * 0.5 * rho_in * v_dc ** 2\n    Gm = m_dot / A_FLOW\n    v_rin = Gm / rho_in\n    dp += K_RISER_IN * 0.5 * rho_in * v_rin ** 2\n    # riser friction (heated, per slice) + unheated ends\n    for p in therm[\"prof\"]:\n        rho_l = air.rho(p[\"Tair\"])\n        Re = Gm * DH / air.mu(p[\"Tair\"])\n        dp += fric(Re) * (DZ / DH) * Gm ** 2 / (2 * rho_l)\n    rho_o = air.rho(T_out_gas)\n    dp += fric(Gm * DH / air.mu(T_in)) * (0.18 / DH) * Gm ** 2 / (2 * rho_in)\n    dp += fric(Gm * DH / air.mu(T_out_gas)) * (0.40 / DH) * Gm ** 2 / (2 * rho_o)\n    # acceleration\n    dp += Gm ** 2 * (1 / rho_o - 1 / rho_in)\n    dp += K_RISER_OUT * 0.5 * rho_o * (Gm / rho_o) ** 2\n    # chimney (per stack)\n    v_ch = (m_dot / 2) / (rho_o * A_STACK)\n    Re_ch = rho_o * v_ch * D_CHIM / air.mu(T_out_gas)\n    dp += (fric(Re_ch) * L_CHIM / D_CHIM + K_CHIM) * 0.5 * rho_o * v_ch ** 2\n\n    return drive - dp, T_stack_exit\n\n\ndef solve_steady(P_elec=None, T_outdoor=275.15, T_bldg=293.15,\n                 T_inlet=None, wind=0.0, cp_wind=0.0, T_plate_fixed=None,\n                 verbose=False):\n    \"\"\"Full coupled solve. Either P_elec (W) or T_plate_fixed (K) given.\"\"\"\n    T_in = T_inlet if T_inlet is not None else T_bldg\n\n    Q_back = 0.0\n    Q_wall_prev = 0.0\n    result = None\n    for outer in range(8):\n        if T_plate_fixed is None:\n            P_to_plate = P_elec - Q_back - Q_wall_prev\n        else:\n            P_to_plate = None\n\n        def mom_residual(m_dot):\n            th = solve_thermal(m_dot, P_to_plate, T_in, T_bldg,\n                               T_plate_fixed=T_plate_fixed)\n            r, _ = loop_dp(m_dot, th, T_in, th[\"T_out\"], T_outdoor,\n                           wind, cp_wind)\n            return r\n\n        m_dot = brentq(mom_residual, 0.02, 6.0, xtol=1e-4)\n        th = solve_thermal(m_dot, P_to_plate, T_in, T_bldg,\n                           T_plate_fixed=T_plate_fixed)\n        _, T_stack_exit = loop_dp(m_dot, th, T_in, th[\"T_out\"], T_outdoor,\n                                  wind, cp_wind)\n        # update parasitic losses\n        Tp_mean = np.mean([p[\"Tp\"] for p in th[\"prof\"]])\n        if T_plate_fixed is None:\n            q_gross = (P_elec - Q_back) / A_PLATE\n            T_pb = Tp_mean + q_gross * 0.0254 / K_STEEL\n            T_h = (T_pb ** 4 + q_gross / (SIG * EPS_EFF_HTR)) ** 0.25\n            R_back = TH_DUR / k_duraboard((T_h + T_bldg) / 2) + 1 / H_OUT\n            Q_back_new = A_HEATER * (T_h - T_bldg) / R_back\n        else:\n            T_h = Tp_mean\n            Q_back_new = Q_back\n        conv = (abs(Q_back_new - Q_back) < 20\n                and abs(th[\"Q_wall\"] - Q_wall_prev) < 20)\n        Q_back = Q_back_new\n        Q_wall_prev = th[\"Q_wall\"]\n        result = (m_dot, th, T_stack_exit, T_h)\n        if conv and outer > 1:\n            break\n\n    m_dot, th, T_stack_exit, T_h = result\n    prof = th[\"prof\"]\n    Tp_mean = np.mean([p[\"Tp\"] for p in prof])\n    # mid-plane values (z = 3.5 m -> between slices 5 and 6, interp)\n    zs = np.array([p[\"z\"] for p in prof])\n    def midp(key):\n        return float(np.interp(3.5, zs, [p[key] for p in prof]))\n    out = dict(\n        m_dot=m_dot, T_in=T_in, T_out=th[\"T_out\"], dT=th[\"T_out\"] - T_in,\n        T_cav=th[\"T_cav\"], Q_removed=th[\"Q_removed\"], Q_back=Q_back,\n        Q_wall=th[\"Q_wall\"], Tp_mean=Tp_mean, Tp_mid=midp(\"Tp\"),\n        Tp_max=max(p[\"Tp\"] for p in prof),\n        Tf_mid=midp(\"Tf\"), Ts_mid=midp(\"Ts\"), Tr_mid=midp(\"Tr\"),\n        Tair_mid=midp(\"Tair\"), T_heater=T_h, T_stack_exit=T_stack_exit,\n        Q_rad_risers=th[\"Q_rad_risers\"], Q_ext_conv=th[\"Q_ext_conv\"],\n        Q_plate_conv=th[\"Q_plate_conv\"], prof=prof,\n        Re_mid=midp(\"Re\"), h_i_mid=midp(\"h_i\"),\n        qf_mid=midp(\"qf\"), qs_mid=midp(\"qs\"), qr_mid=midp(\"qr\"),\n    )\n    if verbose:\n        _print(out)\n    return out\n\n\ndef _print(o):\n    print(f\"m_dot        = {o['m_dot']:.3f} kg/s ({o['m_dot']*60:.1f} kg/min)\")\n    print(f\"T_in/T_out   = {o['T_in']-273.15:.1f} / {o['T_out']-273.15:.1f} C\"\n          f\"   dT = {o['dT']:.1f} K\")\n    print(f\"T_cav        = {o['T_cav']-273.15:.1f} C\")\n    print(f\"plate: mean {o['Tp_mean']-273.15:.0f} C, mid {o['Tp_mid']-273.15:.0f} C,\"\n          f\" max {o['Tp_max']-273.15:.0f} C ; heater {o['T_heater']-273.15:.0f} C\")\n    print(f\"riser7 mid-plane: front {o['Tf_mid']-273.15:.1f} C,\"\n          f\" side {o['Ts_mid']-273.15:.1f} C, rear {o['Tr_mid']-273.15:.1f} C,\"\n          f\" air {o['Tair_mid']-273.15:.1f} C\")\n    print(f\"Q_removed(air) = {o['Q_removed']/1e3:.1f} kW; Q_back = \"\n          f\"{o['Q_back']/1e3:.1f} kW; Q_cavwall = {o['Q_wall']/1e3:.1f} kW\")\n    print(f\"radiation to risers = {o['Q_rad_risers']/1e3:.1f} kW; \"\n          f\"ext conv to risers = {o['Q_ext_conv']/1e3:.1f} kW; \"\n          f\"plate conv = {o['Q_plate_conv']/1e3:.1f} kW\")\n    print(f\"Re_mid = {o['Re_mid']:.0f}, h_int mid = {o['h_i_mid']:.1f} W/m2K\")\n    print(f\"stack exit T = {o['T_stack_exit']-273.15:.1f} C\")\n\n\nif __name__ == \"__main__\":\n    print(\"=== Case 1: baseline, 82 kWe, outdoor 2 C, building 20 C ===\")\n    solve_steady(P_elec=82e3, T_outdoor=275.15, T_bldg=293.15, verbose=True)\n","structuredPatch":[{"oldStart":230,"oldLines":9,"newStart":230,"newLines":10,"lines":["                 Ts_n = face_T(qs, \"side\", Ts, -cond_f - cond_r)","                 Tr_n = face_T(qr, \"rear\", Tr, cond_r + q_fr * A_fr)","                 dmax = max(abs(Tf_n - Tf), abs(Ts_n - Ts), abs(Tr_n - Tr))","-                Tf += 0.6 * (Tf_n - Tf)","-                Ts += 0.6 * (Ts_n - Ts)","-                Tr += 0.6 * (Tr_n - Tr)","+                clip = lambda T: min(max(T, 220.0), 2200.0)","+                Tf = clip(Tf + 0.6 * (Tf_n - Tf))","+                Ts = clip(Ts + 0.6 * (Ts_n - Ts))","+                Tr = clip(Tr + 0.6 * (Tr_n - Tr))","                 if dmax < 0.02:","                     break","             # slice heat into the air"]}],"userModified":false,"replaceAll":false}}
