s):","-    \"\"\"radiosity with ALL surfaces temperature-specified except adiabatic.\"\"\"","-    n = 5","-    A = np.zeros((n, n))","-    b = np.zeros(n)","-    Ts_all = [Tp, *T_faces]","-    for i in range(4):","-        A[i] = -(1 - EPS_VEC[i]) * F_MAT[i]","-        A[i, i] += 1.0","-        b[i] = EPS_VEC[i] * SIG * Ts_all[i] ** 4","-    A[4] = -F_MAT[4]","-    A[4, 4] += 1.0","-    J = np.linalg.solve(A, b)","-    H = F_MAT @ J","-    q = J - H","-    T_ad = (J[4] / SIG) ** 0.25","-    return -q[1], -q[2], -q[3], T_ad, q[0]","-","-"," def loop_dp(m_dot, therm, T_in, T_out_gas, T_amb, wind=0.0, cp_wind=0.0):","-    \"\"\"buoyancy minus losses, Pa (positive drives flow).\"\"\"","+    \"\"\"buoyancy minus losses, Pa (positive accelerates the flow).\"\"\"","     rho_amb = air.rho(T_amb)","     rho_in = air.rho(T_in)"," ","-    # --- buoyancy: integral of rho*g*dz around the loop vs ambient column","     drive = rho_amb * G * (Z_DISCHARGE - Z_DC_IN)","-    # downcomer + inlet plenum (descending, at T_in)","-    drive += rho_in * G * (Z_DC_IN - Z_RISER_IN)   # descending leg helps if dense","-    drive -= rho_in * G * 0.0","-    # actually: sum rho*g*dz over the upward path from riser inlet to discharge","+    drive += rho_in * G * (Z_DC_IN - Z_RISER_IN)","     col = 0.0","-    # unheated riser bottom","     col += air.rho(T_in) * (Z_HEAT_BOT - Z_RISER_IN)","-    # heated riser","     for p in therm[\"prof\"]:","         col += air.rho(p[\"Tair\"]) * DZ","-    # unheated riser top + outlet plenum to chimney port","     col += air.rho(T_out_gas) * (Z_RISER_TOP - (Z_HEAT_BOT + L_HEAT))","     col += air.rho(T_out_gas) * (Z_CHIM_PORT - Z_RISER_TOP)","-    # chimney vertical, cooling along height (per stack m/2)","     T = T_out_gas","     nz = 20","     dzc = L_CHIM_VERT / nz"]},{"oldStart":335,"oldLines":18,"newStart":310,"newLines":14,"lines":["         T -= UA_CHIM_PER_M * dzc * (T - T_amb) / ((m_dot / 2) * cp)","     T_stack_exit = T","     drive -= col * G","-    #